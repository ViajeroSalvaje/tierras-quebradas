<div class="{{cssClass}} flexcol" autocomplete="off" style="height:100%;width:100%;">

  <section class="item-body">
    <div class="field-group full-width" style="margin-bottom:8px;">
      <label>Nombre</label>
      <input type="text" name="name" value="{{item.name}}" placeholder="Nombre del arma" />
    </div>
    <div class="item-grid">
      <div class="field-group">
        <label>Daño</label>
        <input type="text" name="system.danoArma" value="{{system.danoArma}}" placeholder="ej: 1d6+2" />
      </div>
      <div class="field-group">
        <label>Tipo de daño</label>
        <select name="system.tipo">
          <option value="cortante"      {{selected system.tipo "cortante"}}>Cortante</option>
          <option value="contundente"   {{selected system.tipo "contundente"}}>Contundente</option>
          <option value="desgarradora"  {{selected system.tipo "desgarradora"}}>Desgarradora</option>
          <option value="penetrante"    {{selected system.tipo "penetrante"}}>Penetrante</option>
        </select>
      </div>
      <div class="field-group">
        <label>Manos</label>
        <select name="system.manos">
          <option value="1m"    {{selected system.manos "1m"}}>1 mano</option>
          <option value="2m"    {{selected system.manos "2m"}}>2 manos</option>
          <option value="ambas" {{selected system.manos "ambas"}}>1 o 2 manos</option>
        </select>
      </div>
      <div class="field-group">
        <label>Longitud</label>
        <select name="system.longitud">
          <option value="corta"     {{selected system.longitud "corta"}}>Corta</option>
          <option value="media"     {{selected system.longitud "media"}}>Media</option>
          <option value="larga"     {{selected system.longitud "larga"}}>Larga</option>
          <option value="muy larga" {{selected system.longitud "muy larga"}}>Muy larga</option>
        </select>
      </div>
      <div class="field-group">
        <label>FUE mín.</label>
        <input type="number" name="system.fue" value="{{system.fue}}" min="0" />
      </div>
      <div class="field-group">
        <label>Carga</label>
        <input type="number" name="system.carga" value="{{system.carga}}" min="0" />
      </div>
      <div class="field-group">
        <label>Recarga (turnos)</label>
        <input type="number" name="system.recarga" value="{{system.recarga}}" min="0" />
      </div>
      <div class="field-group">
        <label>Habilidad</label>
        <input type="text" name="system.habilidad" value="{{system.habilidad}}" placeholder="ej: armasEspada" />
      </div>
      <div class="field-group">
        <label>Alcance</label>
        <select name="system.alcance">
          <option value="contacto"   {{selected system.alcance "contacto"}}>Contacto (CC)</option>
          <option value="arrojadiza" {{selected system.alcance "arrojadiza"}}>Arrojadiza</option>
          <option value="proyectil"  {{selected system.alcance "proyectil"}}>Proyectil (PR)</option>
        </select>
      </div>
      <div class="field-group">
        <label>No Letal</label>
        <input type="checkbox" name="system.noLetal" {{checked system.noLetal}} />
      </div>
      <div class="field-group">
        <label>Precio</label>
        <input type="number" name="system.precio" value="{{system.precio}}" min="0" />
      </div>
    </div>
    <div class="field-group full-width">
      <label>Propiedades</label>
      <input type="text" name="system.propiedades" value="{{system.propiedades}}" />
    </div>
    <div class="field-group full-width">
      <label>Descripción</label>
      <textarea name="system.descripcion" rows="4">{{system.descripcion}}</textarea>
    </div>
  </section>
</div>
