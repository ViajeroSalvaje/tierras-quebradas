<div style="height:100%;width:100%;display:flex;flex-direction:column;">
  <div class="item-body" style="flex:1;overflow-y:auto;padding:8px 12px;display:flex;flex-direction:column;gap:10px;">

    <h1 style="margin:0;padding:0;"><input type="text" name="name" value="{{item.name}}" placeholder="{{localize "TQ.Placeholders.NombreOrigen"}}" /></h1>

    <div class="tq-field-group full">
      <label>{{localize "TQ.General.Descripcion"}}</label>
      <textarea name="system.descripcion" rows="4">{{system.descripcion}}</textarea>
    </div>

    <div style="display:flex;gap:10px;">
      <div class="tq-field-group" style="flex:1;">
        <label>{{localize "TQ.Origen.IdiomaNativo"}}</label>
        <input type="text" name="system.idiomaNoativo" value="{{system.idiomaNoativo}}" />
      </div>
      <div class="tq-field-group" style="flex:1;">
        <label>{{localize "TQ.Creacion.religion"}}</label>
        <input type="text" name="system.religion" value="{{system.religion}}" />
      </div>
      <div class="tq-field-group" style="width:80px;">
        <label>{{localize "TQ.Origen.BonusPP"}}</label>
        <input type="number" name="system.ppBonus" value="{{system.ppBonus}}" />
      </div>
    </div>

    <div class="tq-field-group full">
      <label>{{localize "TQ.General.ModificadoresHabilidades"}}</label>
      <table style="width:100%;font-size:12px;">
        <thead class="origen-habs-thead">
          <tr>
            <th style="text-align:left;">{{localize "TQ.General.Habilidad"}}</th>
            <th style="text-align:left;">Nombre (idioma)</th>
            <th style="width:60px;text-align:center;">{{localize "TQ.General.Bonus"}}</th>
            <th style="width:30px;text-align:center;"><a class="origen-hab-add" title="{{localize "TQ.Botones.Anadir"}}">+</a></th>
          </tr>
        </thead>
        <tbody>
          {{#each habilidadesLista as |h|}}
          <tr>
            <td style="width:40%;">
              <select class="origen-hab-clave" data-index="{{h.index}}" data-field="clave" style="width:100%;">
                <option value="">— Seleccionar —</option>
                {{#each h.opciones as |op|}}<option value="{{op.clave}}" {{#if op.selected}}selected{{/if}}>{{op.label}}</option>{{/each}}
              </select>
            </td>
            <td>
              <input type="text" class="origen-hab-clave" data-index="{{h.index}}" data-field="nombre"
                     value="{{h.nombre}}" style="width:100%;" placeholder="—" />
            </td>
            <td>
              <input type="number" class="origen-hab-bonus" data-index="{{h.index}}" data-field="bonus"
                     value="{{h.bonus}}" style="width:55px;text-align:center;" />
            </td>
            <td>
              <a class="origen-hab-del" data-index="{{h.index}}"
                 style="color:var(--tq-red-dmg);cursor:pointer;font-size:12px;">
                <i class="fas fa-trash"></i>
              </a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

  </div>
</div>
