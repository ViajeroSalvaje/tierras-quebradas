<div class="tierras-quebradas sheet item idioma flexcol" autocomplete="off" style="height:100%;width:100%;">
  <section class="item-body" style="padding:10px 14px;display:flex;flex-direction:column;gap:10px;">

    <h1><input type="text" name="name" value="{{item.name}}" placeholder="{{localize "TQ.Placeholders.NombreIdioma"}}" /></h1>

    <div style="display:flex;align-items:center;gap:8px;">
      <label style="margin:0;">{{localize "TQ.Idioma.FormaEscrita"}}</label>
      <a class="tq-circulo toggle-estado {{#if system.escrita}}marcado{{/if}}" data-campo="system.escrita" style="width:16px;height:16px;flex-shrink:0;"></a>
    </div>

    <div class="tq-field-group full-width" style="flex:1;">
      <label>{{localize "TQ.General.Descripcion"}}</label>
      <textarea name="system.descripcion" rows="6" style="resize:vertical;">{{system.descripcion}}</textarea>
    </div>

  </section>
</div>
