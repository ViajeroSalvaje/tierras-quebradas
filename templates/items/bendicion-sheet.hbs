<div class="{{cssClass}} flexcol" autocomplete="off" style="height:100%;width:100%;">

  <section class="item-body">
    <h1><input type="text" name="name" value="{{item.name}}" placeholder="{{localize "TQ.Placeholders.NombreBendicion"}}" /></h1>
    <div class="item-grid">
      <div class="tq-field-group">
        <label>{{localize "TQ.Bendicion.CosteESP"}}</label>
        <input type="number" name="system.coste" value="{{system.coste}}" min="0" />
      </div>
      <div class="tq-field-group">
        <label>{{localize "TQ.General.Tipo"}}</label>
        <select name="system.tipo">
          <option value="pasiva" {{selected system.tipo "pasiva"}}>{{localize "TQ.Bendicion.Pasiva"}}</option>
          <option value="activa" {{selected system.tipo "activa"}}>{{localize "TQ.Bendicion.Activa"}}</option>
        </select>
      </div>
      {{#if (tq-eq system.tipo "activa")}}
      <div class="tq-field-group">
        <label>{{localize "TQ.Bendicion.CostePM"}}</label>
        <input type="number" name="system.pmCoste" value="{{system.pmCoste}}" min="0" />
      </div>
      {{/if}}
    </div>
    <div class="tq-field-group full-width">
      <label>{{localize "TQ.General.Efecto"}}</label>
      <textarea name="system.efecto" rows="5">{{system.efecto}}</textarea>
    </div>
  </section>
</div>
