<div class="tq-enfrentada-dialog">
  <div class="tq-enfrentada-iniciador">
    <span class="tq-enfrentada-quien">{{habNombreA}}</span>
    <span class="tq-enfrentada-valor">{{habTotalA}}</span>
  </div>

  <div class="tq-enfrentada-mod">
    <label>{{localize "TQ.Dialogo.Bonificador"}}</label>
    <input type="number" name="modificador" value="0" step="1" style="width:60px;" />
  </div>

  {{#if tieneTarget}}
  <div class="tq-enfrentada-oponente">
    <label>{{localize "TQ.Dialogo.HabilidadDe"}} <strong>{{nombreTarget}}</strong>:</label>
    <select name="habOponente" style="width:100%;margin-top:4px;">
      {{#each habsTarget as |h|}}
      <option value="{{h.total}}|{{h.nombre}}">{{h.nombre}} ({{h.total}})</option>
      {{/each}}
    </select>
  </div>
  {{else}}
  <div class="tq-enfrentada-oponente tq-enfrentada-no-target">
    <label>{{localize "TQ.Dialogo.Oponente"}}</label>
    <select name="actorUuid" style="width:100%;margin-top:4px;">
      <option value="">{{localize "TQ.Dialogo.EligeActor"}}</option>
      {{#each actoresEscena as |a|}}
      <option value="{{a.uuid}}">{{a.name}}</option>
      {{/each}}
    </select>
    <label style="margin-top:8px;">{{localize "TQ.Dialogo.Habilidad"}}</label>
    <select name="habOponente" style="width:100%;margin-top:4px;" disabled>
      <option value="">{{localize "TQ.Dialogo.EligeActorPrimero"}}</option>
    </select>
  </div>
  {{/if}}
</div>
