<div class="lh-dialog">

  {{!-- Cabecera --}}
  <div class="lh-header">
    <span class="lh-nombre">{{hechizo.name}}</span>
    <span class="lh-sintaxis">{{hechizo.system.verbo}}{{#if hechizo.system.esfera}} {{hechizo.system.esfera}}{{/if}}</span>
  </div>
  <div class="lh-stats">
    <span>DIF <strong>{{dif}}</strong></span>
    <span class="lh-sep">·</span>
    <span>{{localize "TQ.Hechizo.PMBase"}} <strong>{{pmBase}}</strong></span>
    <span class="lh-sep">·</span>
    <span>{{localize "TQ.Dialogo.Puntuacion"}} <strong>{{puntuacion}}</strong></span>
    <span class="lh-sep">·</span>
    <span>PM {{pmActual}} / {{pmMaxTotal}}</span>
  </div>

  {{!-- PM variable --}}
  {{#if pmVariable}}
  <div class="lh-fila">
    <label>{{localize "TQ.Hechizo.PMGastar"}}</label>
    <input type="number" name="pmElegido" value="{{pmMin}}" min="{{pmMin}}" max="{{pmMax}}" class="lh-input-num" />
  </div>
  {{else}}
  <input type="hidden" name="pmElegido" value="{{pmMin}}" />
  {{/if}}

  {{!-- Blancos y duración --}}
  <div class="lh-grid-3">
    <div class="lh-campo">
      <label>{{localize "TQ.Hechizo.Blancos"}} <span class="lh-hint">(+{{pmBase}} PM/extra)</span></label>
      <input type="number" name="blancos" value="1" min="1" max="10" class="lh-input-num" />
    </div>
    <div class="lh-campo">
      <label>MD</label>
      <input type="number" name="md" value="0" class="lh-input-num" />
    </div>
    <div class="lh-campo">
      <label>{{localize "TQ.Hechizo.Duracion"}}</label>
      <select name="duracion">
        <option value="standard">{{localize "TQ.Hechizo.DuracionEstandar"}}</option>
        <option value="minutos">{{localize "TQ.Hechizo.DuracionMinutos"}}</option>
        <option value="horas">{{localize "TQ.Hechizo.DuracionHoras"}}</option>
      </select>
    </div>
  </div>

  {{!-- Modificadores --}}
  <div class="lh-mod-box">
    <div class="lh-mod-titulo">{{localize "TQ.Hechizo.ModificadoresLanzamiento"}}</div>
    <div class="lh-checks">
      <label class="lh-check"><input type="checkbox" name="ceremonia" class="lh-check-hidden" /><span class="tq-circulo lh-check-circulo"></span> {{localize "TQ.Hechizo.Ceremonia"}}</label>
      <label class="lh-check"><input type="checkbox" name="grimorio" class="lh-check-hidden" /><span class="tq-circulo lh-check-circulo"></span> {{localize "TQ.Hechizo.Grimorio"}}</label>
      <label class="lh-check"><input type="checkbox" name="acelerar" class="lh-check-hidden" /><span class="tq-circulo lh-check-circulo"></span> {{localize "TQ.Hechizo.Acelerar"}}</label>
    </div>
    <div class="lh-campo" style="margin-top:8px;">
      <label>{{localize "TQ.Hechizo.LimitacionFisica"}}</label>
      <select name="limFisica">
        <option value="0">{{localize "TQ.Hechizo.SinPenalizacion"}}</option>
        <option value="-1">{{localize "TQ.Hechizo.UnaManoOcupada"}}</option>
        <option value="-2">{{localize "TQ.Hechizo.SinHablar"}}</option>
      </select>
    </div>
  </div>

</div>
