<div class="tq-tirada-resultado {{css}}">

  {{!-- Cabecera --}}
  <div class="tq-chat-header">
    <span class="tq-chat-etiqueta">{{etiqueta}}</span>
    <span class="tq-chat-badges">
      {{#if debilitado}}<span class="tq-chat-badge" title="Debilitado: d6">d6</span>{{/if}}
      {{#if dolorExtremo}}<span class="tq-chat-badge" title="Dolor extremo">−2</span>{{/if}}
    </span>
  </div>

  {{#if topeInfo}}
  <div class="tq-chat-tope">Topado: {{topeInfo.label}} ({{topeInfo.valor}})</div>
  {{/if}}

  {{!-- Resultado grande --}}
  <div class="tq-chat-resultado">{{localize resultado.label}}</div>
  {{#if criticos}}
  <div class="tq-chat-criticos">{{criticos}}</div>
  {{/if}}
  {{#if pasionEfecto}}
  <div class="tq-chat-pasion" style="font-size:calc(1em + 1px);">{{pasionEfecto}}</div>
  {{/if}}

  {{#if esEnfrentada}}
  {{!-- Enfrentada: dos columnas --}}
  <div class="tq-melee-grid">
    <div class="tq-melee-col">
      <div class="tq-melee-titulo">{{nombreA}} <span class="tq-enfrentada-hab">({{habNombreA}})</span></div>
      <div class="tq-melee-nums">
        <span><i class="fas fa-dice-d10"></i> <strong>{{dadoDisplayA}}</strong></span>
        <span>+ {{puntuacionA}}</span>
        {{#if bonificadorA}}<span>{{#if (tq-gt bonificadorA 0)}}+{{/if}}{{bonificadorA}}</span>{{/if}}
        <span class="tq-melee-total">= <strong>{{totalA}}</strong></span>
      </div>
    </div>
    <div class="tq-melee-col rival">
      <div class="tq-melee-titulo">{{nombreB}} <span class="tq-enfrentada-hab">({{habNombreB}})</span></div>
      <div class="tq-melee-nums">
        <span><i class="fas fa-dice-d10"></i> <strong>{{dadoDisplayB}}</strong></span>
        <span>+ {{puntuacionB}}</span>
        <span class="tq-melee-total">= <strong>{{totalB}}</strong></span>
      </div>
    </div>
  </div>
  <div class="tq-chat-exitos-fila">
    {{#if (tq-gt exitos 0)}}+{{/if}}{{exitos}} éxitos
  </div>

  {{else if esMelee}}
  {{!-- Melé: dos columnas --}}
  <div class="tq-melee-grid">
    <div class="tq-melee-col">
      <div class="tq-melee-titulo">PJ</div>
      <div class="tq-melee-nums">
        <span><i class="fas fa-dice-d10"></i> <strong>{{dadoDisplay}}</strong></span>
        <span>+ {{#if puntuacionMostrada}}{{puntuacionMostrada}}{{else}}{{puntuacion}}{{/if}}</span>
        {{#each modDesglose as |m|}}<span>{{m.signo}} {{m.valorAbs}} ({{m.label}})</span>{{/each}}
        {{#if bonificador}}<span>{{#if (tq-gt bonificador 0)}}+{{/if}}{{bonificador}}</span>{{/if}}
        {{#if modLongitud}}<span>+{{modLongitud}} (long.)</span>{{/if}}
        <span class="tq-melee-total">= <strong>{{total}}</strong></span>
      </div>
    </div>
    <div class="tq-melee-col rival">
      <div class="tq-melee-titulo">{{rivalNombre}}</div>
      <div class="tq-melee-nums">
        <span><i class="fas fa-dice-d10"></i> <strong>{{dadoDisplayRival}}</strong></span>
        <span>+ {{puntuacionRival}}</span>
        {{#if bonificadorRival}}<span>{{#if (tq-gt bonificadorRival 0)}}+{{/if}}{{bonificadorRival}}</span>{{/if}}
        {{#if modLongitudRival}}<span>+{{modLongitudRival}} (long.)</span>{{/if}}
        <span class="tq-melee-total">= <strong>{{totalRival}}</strong></span>
      </div>
    </div>
  </div>
  <div class="tq-chat-exitos-fila">
    {{#if (tq-gt exitos 0)}}+{{/if}}{{exitos}} éxitos
  </div>
  {{#if resolucionTablas}}
  <div class="tq-chat-tablas-nota">{{resolucionTablas}}</div>
  {{/if}}
  {{else if desgloseHechizo}}
  {{!-- Hechizo: desglose vertical --}}
  <div class="tq-hechizo-desglose">
    <div class="tq-hechizo-fila" style="flex-wrap:wrap;">
      <span class="tq-hechizo-etiq"><i class="fas fa-dice-d10"></i> {{dadoDisplay}}</span>
      {{#each desgloseHechizo.habilidades as |sk|}}{{#if sk.esMinimo}}
      <span class="tq-hechizo-etiq">+</span>
      <span class="tq-hechizo-etiq">{{sk.nombre}}</span>
      <span class="tq-hechizo-val">{{sk.puntuacion}}</span>
      {{/if}}{{/each}}
      {{#each modDesglose as |m|}}
      <span class="tq-hechizo-val">{{m.signo}} {{m.valorAbs}} ({{m.label}})</span>
      {{/each}}
      <span class="tq-hechizo-etiq">=</span>
      <span class="tq-hechizo-val"><strong>{{total}}</strong></span>
    </div>
    <div class="tq-hechizo-vs">
      <span class="tq-hechizo-vs-texto">vs</span>
      <span class="tq-hechizo-dif">{{dificultad}}</span>
    </div>
    <div class="tq-hechizo-resultado-fila">
      <span class="tq-exitos">{{#if (tq-gt exitos 0)}}+{{/if}}{{exitos}} éxitos</span>
    </div>
  </div>

  {{else}}
  {{!-- Normal: fila de cálculo --}}
  <div class="tq-chat-desglose">
    <span class="tq-dado"><i class="fas fa-dice-d10"></i> {{dadoDisplay}}</span>
    <span class="tq-sep">+</span>
    <span>{{#if puntuacionMostrada}}{{puntuacionMostrada}}{{else}}{{puntuacion}}{{/if}}{{#if etiquetaEnDesglose}} ({{etiqueta}}){{/if}}</span>
    {{#each modDesglose as |m|}}
    <span class="tq-sep">{{m.signo}}</span>
    <span>{{m.valorAbs}} ({{m.label}})</span>
    {{/each}}
    {{#if bonificador}}
    <span class="tq-sep">{{#if (tq-gt bonificador 0)}}+{{/if}}</span>
    <span>{{bonificador}}</span>
    {{/if}}
    <span class="tq-sep">=</span>
    <span class="tq-total">{{total}}</span>
    <span class="tq-sep tq-vs">vs</span>
    <span class="tq-dif">{{dificultad}}</span>
    <span class="tq-sep">→</span>
    <span class="tq-exitos">{{#if (tq-gt exitos 0)}}+{{/if}}{{exitos}}</span>
  </div>
  {{/if}}

  {{!-- Daño del PJ --}}
  {{#if pd}}
  <div class="tq-chat-danho">
    {{#if pd.total}}
    {{pd.formula}} = <strong>{{pd.total}} PD</strong>{{#if pd.noLetal}} <em>(No letal)</em>{{/if}}
    {{#if proteccionTarget}} — {{proteccionTarget}} prot. → <strong>{{danhoAplicado}} aplicados</strong>{{/if}}
    {{else}}
    {{pd.formula}}
    {{/if}}
  </div>
  {{/if}}

  {{!-- Daño del rival --}}
  {{#if pdRival}}
  <div class="tq-chat-danho rival">
    {{rivalNombre}}: {{pdRival.formula}}
    {{#if pdRival.total}}
    = <strong>{{pdRival.total}} PD</strong>
    {{#if proteccionJugador}} — {{proteccionJugador}} prot. → <strong>{{danhoRivalAplicado}} aplicados</strong>{{/if}}
    {{/if}}
  </div>
  {{/if}}

  {{#if mostrarFortuna}}
  <div class="tq-fortuna-actions">
    <button class="tq-fortuna-repetir" type="button" data-actor-id="{{actorId}}">
      Repetir Tirada - 1 Fortuna
    </button>
  </div>
  {{/if}}

</div>
