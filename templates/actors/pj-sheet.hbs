<div class="{{cssClass}}" autocomplete="off" style="display:flex;flex-direction:column;height:100%;width:100%;position:relative;">

  {{#if imagenLealtad}}
  <img class="lealtad-cabecera" src="{{imagenLealtad}}" alt="" />
  {{/if}}

  {{!-- CABECERA --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="{{localize "TQ.Placeholders.NombrePersonaje"}}" />
      </h1>
      <div class="header-info">
        {{#if items.especie}}
        <div class="tq-field-group especie-slot activa">
          <label>{{localize "TQ.Actor.Especie"}}</label>
          <span class="especie-nombre">{{items.especie.name}}</span>
        </div>
        {{else}}
        <div class="tq-field-group especie-slot vacia">
          <label>{{localize "TQ.Actor.Especie"}}</label>
          <span class="especie-vacia">{{localize "TQ.Actor.EspecieVacia"}}</span>
        </div>
        {{/if}}
        {{#if items.origen}}
        <div class="tq-field-group especie-slot activa">
          <label>{{localize "TQ.Actor.OrigenLabel"}}</label>
          <span class="especie-nombre">{{items.origen.name}}</span>
        </div>
        {{else}}
        <div class="tq-field-group especie-slot vacia">
          <label>{{localize "TQ.Actor.OrigenLabel"}}</label>
          <span class="especie-vacia">{{localize "TQ.Actor.OrigenVacio"}}</span>
        </div>
        {{/if}}
        {{#if items.profesion}}
        <div class="tq-field-group especie-slot activa">
          <label>{{localize "TQ.Actor.ProfesionLabel"}}</label>
          <span class="especie-nombre">{{items.profesion.name}}</span>
        </div>
        {{else}}
        <div class="tq-field-group especie-slot vacia">
          <label>{{localize "TQ.Actor.ProfesionLabel"}}</label>
          <span class="especie-vacia">{{localize "TQ.Actor.ProfesionVacia"}}</span>
        </div>
        {{/if}}
        <div class="tq-field-group">
          <label>{{localize "TQ.Creacion.edad"}}</label>
          <span style="width:50px;display:inline-block;">{{system.edad}}</span>
        </div>
        <div class="tq-field-group">
          <label>PP</label>
          <input type="number" name="system.puntosPP" value="{{system.puntosPP}}" style="width:45px;" />
        </div>
      </div>
    </div>
  </header>

  {{!-- PESTAÑAS --}}
  <nav class="sheet-tabs" data-group="primary">
    <a class="item {{#if (tq-eq activeTab 'hoja1')}}active{{/if}}" data-tab="hoja1">{{localize "TQ.Tabs.hoja1"}}</a>
    <a class="item {{#if (tq-eq activeTab 'combate')}}active{{/if}}" data-tab="combate">{{localize "TQ.Tabs.CombateEquipo"}}</a>
    <a class="item {{#if (tq-eq activeTab 'magia')}}active{{/if}}" data-tab="magia">{{localize "TQ.Tabs.magia"}}</a>
    <a class="item {{#if (tq-eq activeTab 'hoja2')}}active{{/if}}" data-tab="hoja2">{{localize "TQ.Tabs.hoja2"}}</a>
  </nav>

  <section class="sheet-body">

    {{!-- ══════════════════════════════════════════════════════════════
         TAB HOJA 1 — PERSONAJE
    ══════════════════════════════════════════════════════════════ --}}
    <div class="tab {{#if (tq-eq activeTab 'hoja1')}}active{{/if}}" data-tab="hoja1">

      {{!-- Fila superior: izquierda (características) + derecha (bases + destino) --}}
      <div class="tq-top-fila">

        {{!-- IZQUIERDA: Características --}}
        <div class="tq-top-izq">

          {{!-- Características principales --}}
          <div class="tq-section-box">
            <div class="tq-section-header">{{localize "TQ.Secciones.Caracteristicas"}}</div>
            <div class="tq-section-content">
              <div class="caract-grid">
                <div class="caract-item">
                  <span class="caract-etiqueta tirar-caracteristica" data-caracteristica="cuerpo">CUE</span>
                  <div class="caract-circulo">
                    <input type="number" name="system.caracteristicas.cuerpo.valor"
                           value="{{system.caracteristicas.cuerpo.valor}}" min="1" max="20" />
                  </div>
                  <span style="font-size:10px;color:var(--tq-text-dim);">{{localize "TQ.Caracteristicas.cuerpo"}}</span>
                </div>
                <div class="caract-item">
                  <span class="caract-etiqueta tirar-caracteristica" data-caracteristica="mente">MEN</span>
                  <div class="caract-circulo">
                    <input type="number" name="system.caracteristicas.mente.valor"
                           value="{{system.caracteristicas.mente.valor}}" min="1" max="20" />
                  </div>
                  <span style="font-size:10px;color:var(--tq-text-dim);">{{localize "TQ.Caracteristicas.mente"}}</span>
                </div>
                <div class="caract-item">
                  <span class="caract-etiqueta tirar-caracteristica" data-caracteristica="espiritu">ESP</span>
                  <div class="caract-circulo">
                    <input type="number" name="system.caracteristicas.espiritu.valor"
                           value="{{system.caracteristicas.espiritu.valor}}" min="1" max="20" />
                  </div>
                  <span style="font-size:10px;color:var(--tq-text-dim);">{{localize "TQ.Caracteristicas.espiritu"}}</span>
                </div>
              </div>
              {{!-- ATR y TAM --}}
              <div class="tq-caract-sec-fila">
                <div class="caract-sec-item">
                  <span class="caract-sec-label">ATR</span>
                  <div class="tq-caract-sec-circulo">
                    <input type="number" name="system.caracteristicas.atractivo.valor"
                           value="{{system.caracteristicas.atractivo.valor}}" min="-5" max="10" />
                  </div>
                  <span style="font-size:9px;color:var(--tq-text-dim);">{{localize "TQ.Caracteristicas.atractivo"}}</span>
                </div>
                <div class="caract-sec-item">
                  <span class="caract-sec-label">TAM</span>
                  <div class="tq-caract-sec-circulo">
                    <input type="number" name="system.caracteristicas.tamano.valor"
                           value="{{system.caracteristicas.tamano.valor}}" min="-3" max="10" />
                  </div>
                  <span style="font-size:9px;color:var(--tq-text-dim);">{{localize "TQ.Caracteristicas.tamano"}}</span>
                </div>
              </div>
              {{!-- Derivadas --}}
              <div class="tq-derivadas-fila">
                <div class="derivada-item">
                  <span class="derivada-label tirar-caracteristica" data-caracteristica="fuerza" title="{{localize "TQ.Tooltips.TirarFuerza"}}" style="cursor:pointer;">{{localize "TQ.Caracteristicas.fuerza"}}</span>
                  <div class="tq-caract-sec-circulo">
                    <span class="derivada-value">{{system.derivadas.fuerza.valor}}</span>
                  </div>
                </div>
                <div class="derivada-item">
                  <span class="derivada-label">{{localize "TQ.Combate.md1m"}}</span>
                  <div class="tq-caract-sec-circulo">
                    <span class="derivada-value">{{system.derivadas.mDano1m.valor}}</span>
                  </div>
                </div>
                <div class="derivada-item">
                  <span class="derivada-label">{{localize "TQ.Combate.md2m"}}</span>
                  <div class="tq-caract-sec-circulo">
                    <span class="derivada-value">{{system.derivadas.mDano2m.valor}}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>{{!-- /tq-top-izq --}}

        {{!-- DERECHA: Bases + Destino + Fortuna + Estorbo --}}
        <div class="tq-top-der">

          {{!-- Bases de habilidades --}}
          <div class="tq-section-box" style="flex:1;">
            <div class="tq-section-header">{{localize "TQ.Secciones.BasesHabilidades"}}</div>
            <div class="tq-section-content">
              <table class="bases-table">
                <tbody>
                  <tr>
                    <td class="base-nombre tirar-base" data-nombre="{{localize "TQ.Bases.agilidad"}}" data-valor="{{system.bases.agilidad.valor}}">{{localize "TQ.Bases.agilidad"}}</td>
                    <td class="base-valor">{{system.bases.agilidad.valor}}</td>
                    <td class="base-formula">CUE − TAM</td>
                  </tr>
                  <tr>
                    <td class="base-nombre tirar-base" data-nombre="{{localize "TQ.Bases.comunicacion"}}" data-valor="{{system.bases.comunicacion.valor}}">{{localize "TQ.Bases.comunicacion"}}</td>
                    <td class="base-valor">{{system.bases.comunicacion.valor}}</td>
                    <td class="base-formula">ESP + ATR</td>
                  </tr>
                  <tr>
                    <td class="base-nombre tirar-base" data-nombre="{{localize "TQ.Bases.cultura"}}" data-valor="{{system.bases.cultura.valor}}">{{localize "TQ.Bases.cultura"}}</td>
                    <td class="base-valor">{{system.bases.cultura.valor}}</td>
                    <td class="base-formula">MEN</td>
                  </tr>
                  <tr>
                    <td class="base-nombre tirar-base" data-nombre="{{localize "TQ.Bases.hechiceria"}}" data-valor="{{system.bases.hechiceria.valor}}">{{localize "TQ.Bases.hechiceria"}}</td>
                    <td class="base-valor">{{system.bases.hechiceria.valor}}</td>
                    <td class="base-formula">(MEN+ESP)/3</td>
                  </tr>
                  <tr>
                    <td class="base-nombre tirar-base" data-nombre="{{localize "TQ.Bases.percepcion"}}" data-valor="{{system.bases.percepcion.valor}}">{{localize "TQ.Bases.percepcion"}}</td>
                    <td class="base-valor">{{system.bases.percepcion.valor}}</td>
                    <td class="base-formula">(MEN+ESP)/2</td>
                  </tr>
                  <tr>
                    <td class="base-nombre tirar-base" data-nombre="{{localize "TQ.Bases.tecnica"}}" data-valor="{{system.bases.tecnica.valor}}">{{localize "TQ.Bases.tecnica"}}</td>
                    <td class="base-valor">{{system.bases.tecnica.valor}}</td>
                    <td class="base-formula">(MEN+CUE)/2</td>
                  </tr>
                  <tr>
                    <td class="base-nombre tirar-base" data-nombre="{{localize "TQ.Bases.vigor"}}" data-valor="{{system.bases.vigor.valor}}">{{localize "TQ.Bases.vigor"}}</td>
                    <td class="base-valor">{{system.bases.vigor.valor}}</td>
                    <td class="base-formula">CUE</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          {{!-- Destino + Fortuna + Carga y Estorbo --}}
          <div class="tq-top-der-recursos">
            {{!-- Destino --}}
            <div class="tq-section-box">
              <div class="tq-section-header">{{localize "TQ.Secciones.Destino"}}</div>
              <div class="tq-section-content">
                <div class="destino-box">
                  <div class="destino-campo">
                    <div class="tq-caract-sec-circulo">
                      <input type="number" name="system.destino.actual"
                             value="{{system.destino.actual}}" min="0" />
                    </div>
                    <label>{{localize "TQ.Destino.SinAsignar"}}</label>
                  </div>
                </div>
              </div>
            </div>
            {{!-- Fortuna --}}
            <div class="tq-section-box">
              <div class="tq-section-header">{{localize "TQ.Recursos.fortuna"}}</div>
              <div class="tq-section-content">
                <div class="tq-fortuna-fila">
                  <button type="button" class="usar-fortuna" title="{{localize "TQ.Tooltips.GastarFortuna"}}">−</button>
                  <div class="fortuna-pips">
                    {{#tq-rango 1 system.fortuna.max}}
                    <span class="fortuna-pip {{#if (tq-gt (tq-add ../system.fortuna.actual 1) this)}}lleno{{/if}}">●</span>
                    {{/tq-rango}}
                  </div>
                  <button type="button" class="recuperar-fortuna" title="{{localize "TQ.Tooltips.RecuperarFortuna"}}">+</button>
                </div>
              </div>
            </div>
            {{!-- Carga y Estorbo --}}
            <div class="tq-section-box">
              <div class="tq-section-header">{{localize "TQ.Secciones.CargaEstorbo"}}</div>
              <div class="tq-section-content" style="display:flex;align-items:center;justify-content:center;">
                <div class="tq-estorbo-fila">
                  <div class="estorbo-field">
                    <label>{{localize "TQ.Combate.carga"}}</label>
                    <span class="estorbo-valor">{{system.carga.valor}}</span>
                  </div>
                  <div class="estorbo-field">
                    <label>{{localize "TQ.Combate.estorbo"}}</label>
                    <span class="estorbo-valor">{{system.estorbo.valor}}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>{{!-- /tq-top-der-recursos --}}

        </div>{{!-- /tq-top-der --}}
      </div>{{!-- /tq-top-fila --}}

      {{!-- PUNTOS DE VIDA (ancho completo) --}}
      <div class="tq-section-box">
        <div class="tq-section-header">{{localize "TQ.Secciones.PuntosVida"}}</div>
        <div class="tq-section-content">
          <div class="tq-pv-main-fila">
            <span class="pv-label">PV</span>
            <input type="number" name="system.salud.pvActual.valor"
                   value="{{system.salud.pvActual.valor}}"
                   class="pv-input {{tq-pv-estado system.salud.pvActual.valor system.salud.pvMax.valor}}" />
            <span class="pv-sep">/</span>
            <span class="pv-max">{{system.salud.pvMax.valor}}</span>

            <span class="tq-estados-fila">
              <span class="estado-item">
                <a class="tq-circulo toggle-estado {{#if system.salud.debilitado}}marcado{{/if}}" data-campo="system.salud.debilitado" title="{{localize "TQ.Salud.debilitado"}}"></a>
                <span class="estado-label {{#if system.salud.debilitado}}activo{{/if}}">{{localize "TQ.Salud.debilitado"}}</span>
              </span>
              <span class="estado-item">
                <a class="tq-circulo toggle-estado {{#if system.salud.incapacitado}}marcado{{/if}}" data-campo="system.salud.incapacitado" title="{{localize "TQ.Salud.incapacitado"}}"></a>
                <span class="estado-label {{#if system.salud.incapacitado}}activo{{/if}}">{{localize "TQ.Salud.incapacitado"}}</span>
              </span>
              <span class="estado-item">
                <a class="tq-circulo toggle-estado estado-peligro {{#if system.salud.desangre}}marcado{{/if}}" data-campo="system.salud.desangre" title="{{localize "TQ.Salud.desangre"}}"></a>
                <span class="estado-label estado-peligro-label {{#if system.salud.desangre}}activo{{/if}}">{{localize "TQ.Salud.desangre"}}</span>
              </span>
              <span class="estado-item">
                <a class="tq-circulo toggle-estado estado-peligro {{#if system.salud.dolorExtremo}}marcado{{/if}}" data-campo="system.salud.dolorExtremo" title="{{localize "TQ.Salud.dolorExtremo"}}"></a>
                <span class="estado-label estado-peligro-label {{#if system.salud.dolorExtremo}}activo{{/if}}">{{localize "TQ.Salud.dolorExtremo"}}</span>
              </span>
              <span class="estado-item">
                <a class="tq-circulo toggle-estado {{#if system.salud.ceguera}}marcado{{/if}}" data-campo="system.salud.ceguera" title="{{localize "TQ.Salud.ceguera"}}"></a>
                <span class="estado-label {{#if system.salud.ceguera}}activo{{/if}}">{{localize "TQ.Salud.ceguera"}}</span>
              </span>
              <span class="estado-item">
                <a class="tq-circulo toggle-estado {{#if system.salud.piernaInutilizada}}marcado{{/if}}" data-campo="system.salud.piernaInutilizada" title="{{localize "TQ.Salud.pierna"}}"></a>
                <span class="estado-label {{#if system.salud.piernaInutilizada}}activo{{/if}}">{{localize "TQ.Salud.pierna"}}</span>
              </span>
              <span class="estado-item">
                <a class="tq-circulo toggle-estado {{#if system.salud.brazoInutilizado}}marcado{{/if}}" data-campo="system.salud.brazoInutilizado" title="{{localize "TQ.Salud.brazo"}}"></a>
                <span class="estado-label {{#if system.salud.brazoInutilizado}}activo{{/if}}">{{localize "TQ.Salud.brazo"}}</span>
              </span>
            </span>
          </div>
        </div>
      </div>

      {{!-- HERIDAS --}}
      <div class="tq-section-box">
        <div class="tq-section-header">{{localize "TQ.Secciones.Heridas"}}</div>
        <div class="tq-section-content">
          <div class="heridas-cabecera">
            <div class="pv-umbrales">
              <span title="{{localize "TQ.Salud.UmbralRasguño"}}">R: {{system.salud.pvRagunos.valor}}</span>
              <span title="{{localize "TQ.Salud.UmbralLeve"}}">HL: {{system.salud.pvLeve.valor}}</span>
              <span title="{{localize "TQ.Salud.UmbralGrave"}}">HG: {{system.salud.pvGrave.valor}}</span>
            </div>
            <div class="heridas-leves-check">
              <span class="heridas-leves-label">{{localize "TQ.Salud.heridasLeves"}}</span>
              <a class="tq-circulo toggle-estado {{#if system.salud.heridasLeves1}}marcado{{/if}}" data-campo="system.salud.heridasLeves1" title="Herida leve 1"></a>
              <a class="tq-circulo toggle-estado {{#if system.salud.heridasLeves2}}marcado{{/if}}" data-campo="system.salud.heridasLeves2" title="Herida leve 2"></a>
              <a class="tq-circulo toggle-estado {{#if system.salud.heridasLeves3}}marcado{{/if}}" data-campo="system.salud.heridasLeves3" title="Herida leve 3"></a>
              <a class="tq-circulo toggle-estado {{#if system.salud.heridasLeves4}}marcado{{/if}}" data-campo="system.salud.heridasLeves4" title="Herida leve 4"></a>
            </div>
            <div class="heridas-leves-check">
              <span class="heridas-leves-label">{{localize "TQ.Salud.heridasGraves"}}</span>
              <a class="tq-circulo toggle-estado {{#if system.salud.heridasGraves1}}marcado{{/if}}" data-campo="system.salud.heridasGraves1" title="Herida grave 1"></a>
              <a class="tq-circulo toggle-estado {{#if system.salud.heridasGraves2}}marcado{{/if}}" data-campo="system.salud.heridasGraves2" title="Herida grave 2"></a>
            </div>
          </div>
        </div>
      </div>

      {{!-- HABILIDADES en 3 columnas --}}
      <div class="tq-section-box">
        <div class="tq-section-header">
          {{localize "TQ.Secciones.Habilidades"}}
          <button type="button" class="tq-btn fin-sesion-px" title="{{localize "TQ.Tooltips.FinSesionPX"}}">{{localize "TQ.Botones.FinSesion"}}</button>
          <button type="button" class="tq-btn fin-aventura-px" title="{{localize "TQ.Tooltips.FinAventuraPX"}}">{{localize "TQ.Botones.FinAventura"}}</button>
        </div>
        <div class="tq-section-content" style="padding:2px;">
          <div class="tq-habilidades-grid">

            {{!-- Columna 1 --}}
            <div class="tq-habilidades-col">
              {{#each col1 as |entry|}}
              <div class="tq-habilidad-fila">
                <a class="tq-circulo toggle-exito {{#if entry.hab.exito}}marcado{{/if}}"
                   data-habilidad="{{entry.key}}" title="Marcar/desmarcar éxito"></a>
                {{#if entry.esIdioma}}
                <a class="tq-habilidad-nombre tirar-habilidad" data-habilidad="{{entry.key}}"
                   data-tq-hab-tooltip="{{entry.tooltip}}">
                  {{#if entry.hab.nombre}}{{entry.hab.nombre}}
                  {{else}}<em style="color:var(--tq-text-dim);">—</em>{{/if}}
                </a>
                {{else}}
                <a class="tq-habilidad-nombre tirar-habilidad" data-habilidad="{{entry.key}}"
                   data-tq-hab-tooltip="{{entry.tooltip}}">
                  {{localize (concat "TQ.Habilidades." entry.key)}}
                </a>
                {{/if}}
                <span class="tq-habilidad-px" data-habilidad="{{entry.key}}" title="PX acumulados — clic para editar">({{entry.hab.px}})</span>
                <span class="tq-habilidad-base-tag">{{tq-base-abrev entry.hab.base}}</span>
                <span class="tq-habilidad-total">{{tq-habilidad-total entry.hab @root.system.bases @root.system.estorbo.valor}}</span>
                <span class="tq-habilidad-nivel">
                  <input type="number" name="system.habilidades.{{entry.key}}.nivel"
                         value="{{entry.hab.nivel}}" min="0" />
                </span>
              </div>
              {{/each}}
            </div>

            {{!-- Columna 2 --}}
            <div class="tq-habilidades-col">
              {{#each col2 as |entry|}}
              <div class="tq-habilidad-fila">
                <a class="tq-circulo toggle-exito {{#if entry.hab.exito}}marcado{{/if}}"
                   data-habilidad="{{entry.key}}" title="Marcar/desmarcar éxito"></a>
                {{#if entry.esIdioma}}
                <a class="tq-habilidad-nombre tirar-habilidad" data-habilidad="{{entry.key}}"
                   data-tq-hab-tooltip="{{entry.tooltip}}">
                  {{#if entry.hab.nombre}}{{entry.hab.nombre}}
                  {{else}}<em style="color:var(--tq-text-dim);">—</em>{{/if}}
                </a>
                {{else}}
                <a class="tq-habilidad-nombre tirar-habilidad" data-habilidad="{{entry.key}}"
                   data-tq-hab-tooltip="{{entry.tooltip}}">
                  {{localize (concat "TQ.Habilidades." entry.key)}}
                </a>
                {{/if}}
                <span class="tq-habilidad-px" data-habilidad="{{entry.key}}" title="PX acumulados — clic para editar">({{entry.hab.px}})</span>
                <span class="tq-habilidad-base-tag">{{tq-base-abrev entry.hab.base}}</span>
                <span class="tq-habilidad-total">{{tq-habilidad-total entry.hab @root.system.bases @root.system.estorbo.valor}}</span>
                <span class="tq-habilidad-nivel">
                  <input type="number" name="system.habilidades.{{entry.key}}.nivel"
                         value="{{entry.hab.nivel}}" min="0" />
                </span>
              </div>
              {{/each}}
            </div>

            {{!-- Columna 3 --}}
            <div class="tq-habilidades-col">
              {{#each col3 as |entry|}}
              <div class="tq-habilidad-fila">
                <a class="tq-circulo toggle-exito {{#if entry.hab.exito}}marcado{{/if}}"
                   data-habilidad="{{entry.key}}" title="Marcar/desmarcar éxito"></a>
                {{#if entry.esIdioma}}
                <a class="tq-habilidad-nombre tirar-habilidad" data-habilidad="{{entry.key}}"
                   data-tq-hab-tooltip="{{entry.tooltip}}">
                  {{#if entry.hab.nombre}}{{entry.hab.nombre}}
                  {{else}}<em style="color:var(--tq-text-dim);">—</em>{{/if}}
                </a>
                {{else}}
                <a class="tq-habilidad-nombre tirar-habilidad" data-habilidad="{{entry.key}}"
                   data-tq-hab-tooltip="{{entry.tooltip}}">
                  {{localize (concat "TQ.Habilidades." entry.key)}}
                </a>
                {{/if}}
                <span class="tq-habilidad-px" data-habilidad="{{entry.key}}" title="PX acumulados — clic para editar">({{entry.hab.px}})</span>
                <span class="tq-habilidad-base-tag">{{tq-base-abrev entry.hab.base}}</span>
                <span class="tq-habilidad-total">{{tq-habilidad-total entry.hab @root.system.bases @root.system.estorbo.valor}}</span>
                <span class="tq-habilidad-nivel">
                  <input type="number" name="system.habilidades.{{entry.key}}.nivel"
                         value="{{entry.hab.nivel}}" min="0" />
                </span>
              </div>
              {{/each}}
            </div>

          </div>{{!-- /tq-habilidades-grid --}}
        </div>
      </div>

      {{!-- Espaciador inferior --}}
      <div style="height:40px;background:var(--tq-parchment);border:none;"></div>

    </div>{{!-- /tab hoja1 --}}


    {{!-- ══════════════════════════════════════════════════════════════
         TAB COMBATE Y EQUIPO
    ══════════════════════════════════════════════════════════════ --}}
    <div class="tab {{#if (tq-eq activeTab 'combate')}}active{{/if}}" data-tab="combate">

      {{!-- ARMAS + MD --}}
      <div class="tq-bottom-fila">

        <div class="tq-section-box" style="flex:1;">
          <div class="tq-section-header">
            <span>{{localize "TQ.Secciones.Armas"}}</span>
            <a class="item-create" data-tipo="arma" title="{{localize "TQ.Tooltips.AnadirArma"}}"><i class="fas fa-plus"></i></a>
          </div>
          <div class="tq-section-content" style="padding:2px;">
            <table class="armas-table">
              <thead>
                <tr>
                  <th></th>
                  <th>{{localize "TQ.General.Nombre"}}</th>
                  <th>{{localize "TQ.General.HabTotal"}}</th>
                  <th>{{localize "TQ.General.Dano"}}</th>
                  <th>{{localize "TQ.General.MD"}}</th>
                  <th>{{localize "TQ.General.Alcance"}}</th>
                  <th>{{localize "TQ.Combate.carga"}}</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {{#each items.armas as |arma|}}
                <tr data-item-id="{{arma.item.id}}">
                  <td>
                    <a class="tirar-arma" data-item-id="{{arma.item.id}}" title="Tirar {{arma.item.name}}">
                      <i class="fas fa-dice-d10"></i>
                    </a>
                  </td>
                  <td>{{arma.item.name}}</td>
                  <td class="arma-hab">
                    <span class="arma-hab-clave" title="{{localize (concat "TQ.Habilidades." arma.item.system.habilidad)}}">{{localize (concat "TQ.Habilidades." arma.item.system.habilidad)}}</span>
                    {{#if arma.habTotal}}<span class="arma-hab-total">({{arma.habTotal}})</span>{{/if}}
                  </td>
                  <td>{{arma.item.system.danoArma}}</td>
                  <td>{{arma.mdStr}}</td>
                  <td>{{arma.item.system.alcance}}</td>
                  <td>{{arma.item.system.carga}}</td>
                  <td class="item-controls">
                    <a class="item-edit" data-item-id="{{arma.item.id}}" title="{{localize "TQ.Tooltips.Editar"}}"><i class="fas fa-edit"></i></a>
                    <a class="item-delete" data-item-id="{{arma.item.id}}" title="{{localize "TQ.Tooltips.Eliminar"}}"><i class="fas fa-trash"></i></a>
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </div>

        {{!-- Mod. Daño --}}
        <div class="tq-section-box" style="flex:0 0 auto;min-width:100px;">
          <div class="tq-section-header">{{localize "TQ.Secciones.ModDano"}}</div>
          <div class="tq-section-content">
            <div class="md-field">
              <span>1M:</span>
              <strong>{{system.derivadas.mDano1m.valor}}</strong>
            </div>
            <div class="md-field">
              <span>2M:</span>
              <strong>{{system.derivadas.mDano2m.valor}}</strong>
            </div>
          </div>
        </div>

      </div>{{!-- /tq-bottom-fila --}}

      {{!-- PROTECCIÓN --}}
      <div class="tq-section-box">
        <div class="tq-section-header">
          <span>{{localize "TQ.Secciones.Proteccion"}}</span>
          <a class="item-create" data-tipo="armadura" title="{{localize "TQ.Tooltips.AnadirArmadura"}}"><i class="fas fa-plus"></i></a>
        </div>
        <div class="tq-section-content" style="padding:2px;">
          <table class="armaduras-table">
            <thead>
              <tr>
                <th>{{localize "TQ.General.Nombre"}}</th>
                <th>{{localize "TQ.Armadura.Proteccion"}}</th>
                <th>{{localize "TQ.General.Zona"}}</th>
                <th>{{localize "TQ.General.Tipo"}}</th>
                <th>{{localize "TQ.Combate.carga"}}</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each items.armaduras as |arm|}}
              <tr data-item-id="{{arm.id}}">
                <td>{{arm.name}}</td>
                <td>{{arm.system.proteccion}}</td>
                <td>{{arm.system.zona}}</td>
                <td>{{arm.system.tipo}}</td>
                <td>{{arm.system.carga}}</td>
                <td class="item-controls">
                  {{#if arm.system.esYelmo}}
                  <a class="toggle-visera {{#if arm.system.viseraBajada}}visera-bajada{{/if}}" data-item-id="{{arm.id}}" title="{{#if arm.system.viseraBajada}}Visera bajada (−2 Perc.) — clic para subir{{else}}Visera subida (−1 Perc.) — clic para bajar{{/if}}">{{#if arm.system.viseraBajada}}Bajada{{else}}Subida{{/if}}</a>
                  {{/if}}
                  <a class="item-edit" data-item-id="{{arm.id}}" title="{{localize "TQ.Tooltips.Editar"}}"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" data-item-id="{{arm.id}}" title="{{localize "TQ.Tooltips.Eliminar"}}"><i class="fas fa-trash"></i></a>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>

      {{!-- Tabla de Lesiones --}}
      <div class="tq-bottom-fila" style="margin-top:6px;">
        <div class="tq-section-box" style="flex:1;">
          <div class="tq-section-header">
            <span>{{localize "TQ.Secciones.Heridas"}}</span>
            <a class="herida-add" title="{{localize "TQ.Tooltips.AnadirHerida"}}"><i class="fas fa-plus"></i></a>
          </div>
          <div class="tq-section-content" style="padding:2px;">
            <table class="heridas-table">
              <thead>
                <tr>
                  <th>{{localize "TQ.General.Tipo"}}</th>
                  <th>{{localize "TQ.General.Descripcion"}}</th>
                  <th>{{localize "TQ.Salud.Dano"}}</th>
                  <th>{{localize "TQ.Salud.sanando"}}</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {{#each system.heridas as |herida idx|}}
                <tr data-idx="{{idx}}">
                  <td>
                    <select name="system.heridas.{{idx}}.tipo">
                      <option value="rasguño" {{selected herida.tipo "rasguño"}}>{{localize "TQ.Salud.OpcionRasguno"}}</option>
                      <option value="leve" {{selected herida.tipo "leve"}}>{{localize "TQ.Salud.OpcionLeve"}}</option>
                      <option value="grave" {{selected herida.tipo "grave"}}>{{localize "TQ.Salud.OpcionGrave"}}</option>
                    </select>
                  </td>
                  <td><input type="text" name="system.heridas.{{idx}}.descripcion" value="{{herida.descripcion}}" /></td>
                  <td class="herida-dano"><input type="number" name="system.heridas.{{idx}}.dano" value="{{herida.dano}}" min="0" /></td>
                  <td class="herida-sanando">
                    <a class="tq-circulo toggle-herida-sanando {{#if herida.sanando}}marcado{{/if}}" data-idx="{{idx}}" title="{{localize "TQ.Salud.sanando"}}"></a>
                  </td>
                  <td class="item-controls">
                    <a class="herida-primeros-auxilios" data-idx="{{idx}}" title="{{localize "TQ.PA.Titulo"}}"><i class="fas fa-medkit"></i></a>
                    <a class="herida-delete" data-idx="{{idx}}" title="{{localize "TQ.Tooltips.Eliminar"}}"><i class="fas fa-trash"></i></a>
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
            <div class="heridas-actions">
              <a class="tirar-lesion tq-btn-lanzar" title="{{localize "TQ.Botones.TablaLesiones"}}"><i class="fas fa-dice-d20"></i> {{localize "TQ.Botones.TablaLesiones"}}</a>
            </div>
          </div>
        </div>
      </div>

      {{!-- EQUIPO --}}
      <div class="tq-section-box" style="margin-bottom:6px;">
        <div class="tq-section-header">
          <span>{{localize "TQ.Secciones.Equipo"}}</span>
          <a class="item-create" data-tipo="objeto" title="{{localize "TQ.Tooltips.AnadirObjeto"}}"><i class="fas fa-plus"></i></a>
        </div>
        <div class="tq-section-content equipo-content">
          {{#each items.objetos as |obj|}}
          <div class="tq-equipo-fila" data-item-id="{{obj.id}}">
            <span class="equipo-nombre">{{obj.name}}</span>
            {{#if obj.system.categoria}}<span class="equipo-cat">{{obj.system.categoria}}</span>{{/if}}
            <span class="equipo-carga">{{obj.system.carga}}</span>
            <span class="item-controls">
              <a class="item-edit" data-item-id="{{obj.id}}"><i class="fas fa-edit"></i></a>
              <a class="item-delete" data-item-id="{{obj.id}}"><i class="fas fa-trash"></i></a>
            </span>
          </div>
          {{/each}}
          {{#each items.consumibles as |con|}}
          <div class="tq-equipo-fila tq-consumible-fila" data-item-id="{{con.id}}">
            <span class="equipo-nombre">{{con.name}}</span>
            <span class="equipo-cat">×{{con.system.dosis}}</span>
            {{#if con.system.efecto}}<span class="equipo-efecto">{{con.system.efecto}}</span>{{/if}}
            <span class="equipo-carga">{{con.system.carga}}</span>
            <span class="item-controls">
              <a class="item-edit" data-item-id="{{con.id}}"><i class="fas fa-edit"></i></a>
              <a class="item-delete" data-item-id="{{con.id}}"><i class="fas fa-trash"></i></a>
            </span>
          </div>
          {{/each}}
          {{#unless items.objetos.length}}{{#unless items.consumibles.length}}
          <p class="equipo-vacio">{{localize "TQ.Secciones.EquipoVacio"}}</p>
          {{/unless}}{{/unless}}
        </div>
      </div>

      {{!-- DINERO --}}
      <div class="tq-dinero-fila">
        <label class="tq-dinero-label">{{localize "TQ.General.MonedasBronce"}}</label>
        <input type="number" name="system.dinero" value="{{system.dinero}}" min="0" class="tq-dinero-input" />
        <div class="tq-dinero-extra">
          <span class="tq-dinero-stat"><label>{{localize "TQ.Combate.carga"}}</label> <span class="estorbo-valor">{{system.carga.valor}}</span></span>
          <span class="tq-dinero-stat"><label>{{localize "TQ.Combate.estorbo"}}</label> <span class="estorbo-valor">{{system.estorbo.valor}}</span></span>
        </div>
      </div>

      {{!-- Espaciador inferior --}}
      <div style="height:40px;background:var(--tq-parchment);border:none;"></div>

    </div>{{!-- /tab combate --}}


    {{!-- ══════════════════════════════════════════════════════════════
         TAB MAGIA
    ══════════════════════════════════════════════════════════════ --}}
    <div class="tab {{#if (tq-eq activeTab 'magia')}}active{{/if}}" data-tab="magia">

      {{!-- Puntos de Magia --}}
      <div class="tq-section-box">
        <div class="tq-section-header">{{localize "TQ.Secciones.PuntosMagia"}}</div>
        <div class="tq-section-content">
          <div class="tq-pm-fila">
            <label>{{localize "TQ.General.PM"}}</label>
            <input type="number" name="system.hechiceria.pmActual"
                   value="{{system.hechiceria.pmActual}}" min="0" />
            <span class="pm-sep">/</span>
            <span class="estorbo-valor">{{system.hechiceria.pmMax}}</span>
            <span class="pm-sep" style="margin:0 4px;">·</span>
            <label>{{localize "TQ.General.EspConsagradoAbrev"}}</label>
            <span class="estorbo-valor">{{system.hechiceria.espirituConsagrado}}</span>
            <span class="pm-sep" style="margin:0 4px;">·</span>
            <label>{{localize "TQ.Magia.BaseHechiceria"}}</label>
            <strong style="color:var(--tq-teal-dark);font-size:17px;">{{system.bases.hechiceria.valor}}</strong>
            <button type="button" class="tq-btn recuperar-pm" style="margin-left:8px;" title="{{localize "TQ.Tooltips.RecuperarPMDurmiendo"}}"><i class="fas fa-moon"></i></button>
          </div>
        </div>
      </div>

      {{!-- Verbos y Esferas en dos columnas --}}
      <div style="display:flex;gap:6px;">

        {{!-- Verbos --}}
        <div class="tq-section-box" style="flex:1;">
          <div class="tq-section-header">{{localize "TQ.Hechiceria.Verbos"}}</div>
          <div class="tq-section-content" style="padding:2px 4px;">
            <div class="hechiceria-lista">
              {{#each system.hechiceria.verbos as |val verbo|}}
              <div class="tq-hechiceria-fila">
                <span class="tq-hechiceria-circulo"></span>
                <span class="hechiceria-nombre">{{localize (concat "TQ.Hechiceria." verbo)}}</span>
                <span class="tq-habilidad-total">{{tq-add @root.system.bases.hechiceria.valor val}}</span>
                <span class="hechiceria-valor">
                  <input type="number" name="system.hechiceria.verbos.{{verbo}}" value="{{val}}" min="0" />
                </span>
              </div>
              {{/each}}
            </div>
          </div>
        </div>

        {{!-- Esferas --}}
        <div class="tq-section-box" style="flex:1;">
          <div class="tq-section-header">{{localize "TQ.Hechiceria.Esferas"}}</div>
          <div class="tq-section-content" style="padding:2px 4px;">
            <div class="hechiceria-lista">
              {{#each system.hechiceria.esferas as |val esfera|}}
              <div class="tq-hechiceria-fila">
                <span class="tq-hechiceria-circulo"></span>
                <span class="hechiceria-nombre">{{localize (concat "TQ.Hechiceria." esfera)}}</span>
                <span class="tq-habilidad-total">{{tq-add @root.system.bases.hechiceria.valor val}}</span>
                <span class="hechiceria-valor">
                  <input type="number" name="system.hechiceria.esferas.{{esfera}}" value="{{val}}" min="0" />
                </span>
              </div>
              {{/each}}
            </div>
          </div>
        </div>

      </div>

      {{!-- Hechizos --}}
      <div class="tq-section-box">
        <div class="tq-section-header">
          <span>{{localize "TQ.Secciones.Hechizos"}}</span>
          <a class="item-create" data-tipo="hechizo"><i class="fas fa-plus"></i></a>
        </div>
        <ul class="hechizos-list">
          {{#each items.hechizos as |hech|}}
          <li class="hechizo-item" data-item-id="{{hech.id}}">
            <div class="hechizo-main">
              <div class="hechizo-nombre-wrap">
                <span class="tq-circulo hechizo-permanent{{#if hech.system.permanent}} marcado{{/if}}" data-item-id="{{hech.id}}" title="{{localize "TQ.Hechizo.EspirituConsagrado"}}"></span>
                <span class="hechizo-nombre">{{hech.name}}</span>
              </div>
              <span class="item-controls">
                <a class="tirar-hechizo tq-btn-lanzar" data-item-id="{{hech.id}}">{{localize "TQ.Botones.Lanzar"}}</a>
                <a class="item-edit" data-item-id="{{hech.id}}"><i class="fas fa-edit"></i></a>
                <a class="item-delete" data-item-id="{{hech.id}}"><i class="fas fa-trash"></i></a>
              </span>
            </div>
            <div class="hechizo-meta">
              {{#if hech.system.verbo}}<span>{{hech.system.verbo}}{{#if hech.system.esfera}} {{hech.system.esfera}}{{/if}}</span><span class="hechizo-sep">|</span>{{/if}}
              <span>DIF. {{hech.system.dificultad}}</span>
              <span class="hechizo-sep">|</span>
              <span>PM {{hech.system.pmCoste}}{{#if (tq-gt hech.system.pmMax hech.system.pmCoste)}}-{{hech.system.pmMax}}{{/if}}</span>
              {{#if (tq-eq hech.system.duracion "instantaneo")}}<span class="hechizo-sep">|</span><span class="hechizo-badge">{{localize "TQ.Hechizo.Inmediato"}}</span>{{/if}}
              {{#if hech.system.requiereTiradaEspiritu}}<span class="hechizo-sep">|</span><span class="hechizo-espiritu">{{localize "TQ.Hechizo.Espiritu"}}</span>{{/if}}
            </div>
          </li>
          {{/each}}
        </ul>
      </div>

      {{!-- Espaciador inferior --}}
      <div style="height:40px;background:var(--tq-parchment);border:none;"></div>

    </div>{{!-- /tab magia --}}


    {{!-- ══════════════════════════════════════════════════════════════
         TAB HOJA 2 — TRASFONDO
    ══════════════════════════════════════════════════════════════ --}}
    <div class="tab {{#if (tq-eq activeTab 'hoja2')}}active{{/if}}" data-tab="hoja2">

      {{!-- FILA PRINCIPAL: columna izq (Lealtad + Pactos + Bendiciones) y der (Info Personal + Ventajas) --}}
      <div style="display:flex;gap:6px;align-items:flex-start;margin-bottom:4px;">

        {{!-- Columna izquierda --}}
        <div style="flex:1;display:flex;flex-direction:column;gap:4px;">

          {{!-- LEALTAD --}}
          <div class="tq-section-box" style="margin-bottom:0;">
            <div class="tq-section-header">{{localize "TQ.Secciones.Lealtad"}}</div>
            <div class="tq-section-content">
              <div class="tq-lealtad-fila">
                <div class="lealtad-item {{#if lealtad.alineado.caos}}lealtad-alineada{{/if}}">
                  <label>{{localize "TQ.Lealtad.caos"}}</label>
                  <div class="lealtad-circulo">
                    <input type="number" name="system.lealtad.caos" value="{{system.lealtad.caos}}" min="0" />
                  </div>
                </div>
                <div class="lealtad-item {{#if lealtad.alineado.ley}}lealtad-alineada{{/if}}">
                  <label>{{localize "TQ.Lealtad.ley"}}</label>
                  <div class="lealtad-circulo">
                    <input type="number" name="system.lealtad.ley" value="{{system.lealtad.ley}}" min="0" />
                  </div>
                </div>
                <div class="lealtad-item {{#if lealtad.alineado.elementos}}lealtad-alineada{{/if}}">
                  <label>{{localize "TQ.Lealtad.elementos"}}</label>
                  <div class="lealtad-circulo">
                    <input type="number" name="system.lealtad.elementos" value="{{system.lealtad.elementos}}" min="0" />
                  </div>
                </div>
                <div class="lealtad-item {{#if lealtad.alineado.antepasados}}lealtad-alineada{{/if}}">
                  <label>{{localize "TQ.Lealtad.antepasados"}}</label>
                  <div class="lealtad-circulo">
                    <input type="number" name="system.lealtad.antepasados" value="{{system.lealtad.antepasados}}" min="0" />
                  </div>
                </div>
              </div>
              <div class="lealtad-divina-campo">
                <label>{{localize "TQ.Lealtad.ActitudDivina"}}</label>
                <select name="system.actitudDivina">
                  <option value="servicial"   {{selected system.actitudDivina "servicial"}}>{{localize "TQ.Lealtad.Actitud.servicial"}}</option>
                  <option value="atemorizado" {{selected system.actitudDivina "atemorizado"}}>{{localize "TQ.Lealtad.Actitud.atemorizado"}}</option>
                  <option value="pragmatico"  {{selected system.actitudDivina "pragmatico"}}>{{localize "TQ.Lealtad.Actitud.pragmatico"}}</option>
                  <option value="rebelde"     {{selected system.actitudDivina "rebelde"}}>{{localize "TQ.Lealtad.Actitud.rebelde"}}</option>
                  <option value="indiferente" {{selected system.actitudDivina "indiferente"}}>{{localize "TQ.Lealtad.Actitud.indiferente"}}</option>
                </select>
              </div>
              <div class="lealtad-divina-campo actitud-efecto">
                {{#if (tq-eq system.actitudDivina "servicial")}}
                  <span class="actitud-desc">{{localize "TQ.Lealtad.Actitud.ServicialDesc"}}</span>
                  <button type="button" class="tq-btn fin-sesion-actitud">{{localize "TQ.Botones.AplicarFinSesion"}}</button>
                {{/if}}
                {{#if (tq-eq system.actitudDivina "atemorizado")}}
                  <span class="actitud-desc">{{localize "TQ.Lealtad.Actitud.AtemoradoDesc"}}</span>
                  <button type="button" class="tq-btn fin-sesion-actitud">{{localize "TQ.Botones.AplicarFinSesion"}}</button>
                {{/if}}
                {{#if (tq-eq system.actitudDivina "pragmatico")}}
                  <span class="actitud-desc">{{localize "TQ.Lealtad.Actitud.PragmaticoDesc"}}</span>
                  <button type="button" class="tq-btn fin-sesion-actitud">{{localize "TQ.Botones.AplicarFinSesion"}}</button>
                {{/if}}
                {{#if (tq-eq system.actitudDivina "rebelde")}}
                  <span class="actitud-desc">{{localize "TQ.Lealtad.Actitud.RebeldeDesc"}}</span>
                  <button type="button" class="tq-btn fin-sesion-actitud">{{localize "TQ.Botones.AplicarFinSesion"}}</button>
                {{/if}}
                {{#if (tq-eq system.actitudDivina "indiferente")}}
                  <span class="actitud-desc">{{localize "TQ.Lealtad.Actitud.IndiferenteDesc"}}</span>
                  <button type="button" class="tq-btn fin-sesion-actitud">{{localize "TQ.Botones.AplicarFinSesion"}}</button>
                {{/if}}
              </div>
              <div class="lealtad-divina-campo">
                <button type="button" class="tq-btn cambiar-lealtad-pm">{{localize "TQ.Botones.CambiarLealtadPM"}}</button>
              </div>
            </div>
          </div>

          {{!-- Pactos --}}
          <div class="tq-section-box" style="margin-bottom:0;">
            <div class="tq-section-header">
              <span>{{localize "TQ.Secciones.Pactos"}}</span>
              <a class="item-create" data-tipo="pacto"><i class="fas fa-plus"></i></a>
            </div>
            <ul class="pactos-list">
              {{#each items.pactos as |pacto|}}
              <li class="pacto-item">
                <span class="pacto-dios">{{pacto.name}}</span>
                <span class="pacto-religion">({{pacto.system.religion}})</span>
                <span class="pacto-esp">{{pacto.system.espirituConsagrado}} ESP</span>
                <span class="item-controls">
                  <a class="tirar-intervencion" data-item-id="{{pacto.id}}" title="{{localize "TQ.Botones.Intervencion"}}">{{localize "TQ.Botones.Intervencion"}}</a>
                  <a class="item-edit" data-item-id="{{pacto.id}}"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" data-item-id="{{pacto.id}}"><i class="fas fa-trash"></i></a>
                </span>
              </li>
              {{/each}}
            </ul>
          </div>

          {{!-- Bendiciones --}}
          <div class="tq-section-box" style="margin-bottom:0;">
            <div class="tq-section-header">
              <span>{{localize "TQ.Secciones.Bendiciones"}}</span>
              <a class="item-create" data-tipo="bendicion"><i class="fas fa-plus"></i></a>
            </div>
            <ul class="bendiciones-list">
              {{#each items.bendiciones as |bend|}}
              <li class="bendicion-item tipo-{{bend.system.tipo}}">
                <span class="bend-nombre">{{bend.name}}</span>
                <span class="bend-coste">{{bend.system.coste}} ESP</span>
                {{#if (tq-eq bend.system.tipo "activa")}}
                <span class="bend-pm">{{bend.system.pmCoste}} PM</span>
                <a class="activar-bendicion" data-item-id="{{bend.id}}" title="{{localize "TQ.Botones.Activar"}}">{{localize "TQ.Botones.Activar"}}</a>
                {{/if}}
                <span class="item-controls">
                  <a class="item-edit" data-item-id="{{bend.id}}"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" data-item-id="{{bend.id}}"><i class="fas fa-trash"></i></a>
                </span>
              </li>
              {{/each}}
            </ul>
          </div>

          <div class="tq-section-box" style="margin-bottom:0;">
            <div class="tq-section-header">
              <span>{{localize "TQ.Secciones.Destino"}}</span>
              <a class="destino-punto-add" title="{{localize "TQ.Tooltips.AnhadirDestino"}}"><i class="fas fa-plus"></i></a>
            </div>
            <div class="tq-section-content">
              <table class="heridas-table">
                <thead>
                  <tr>
                    <th>{{localize "TQ.General.Tipo"}}</th>
                    <th>{{localize "TQ.General.Descripcion"}}</th>
                    <th>{{localize "TQ.General.Valor"}}</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {{#each system.destino.puntos as |punto idx|}}
                  <tr data-idx="{{idx}}">
                    <td>
                      <select name="system.destino.puntos.{{idx}}.tipo">
                        <option value="objeto"   {{selected punto.tipo "objeto"}}>{{localize "TQ.Destino.Tipos.objeto"}}</option>
                        <option value="persona"  {{selected punto.tipo "persona"}}>{{localize "TQ.Destino.Tipos.persona"}}</option>
                        <option value="secreto"  {{selected punto.tipo "secreto"}}>{{localize "TQ.Destino.Tipos.secreto"}}</option>
                        <option value="escenario" {{selected punto.tipo "escenario"}}>{{localize "TQ.Destino.Tipos.escenario"}}</option>
                      </select>
                    </td>
                    <td><input type="text" name="system.destino.puntos.{{idx}}.descripcion" value="{{punto.descripcion}}" /></td>
                    <td><input type="number" name="system.destino.puntos.{{idx}}.valor" value="{{punto.valor}}" min="0" class="destino-punto-valor" /></td>
                    <td class="item-controls">
                      <a class="destino-punto-delete" data-idx="{{idx}}" title="{{localize "TQ.Tooltips.Eliminar"}}"><i class="fas fa-trash"></i></a>
                    </td>
                  </tr>
                  {{/each}}
                </tbody>
              </table>
              <div class="destino-gastado-total">
                <label>{{localize "TQ.Destino.ValorTotal"}}</label>
                <span>{{destinoTotal}}</span>
              </div>
            </div>
          </div>

        </div>{{!-- /col izq --}}

        {{!-- Columna derecha --}}
        <div style="flex:1;display:flex;flex-direction:column;gap:4px;">

          {{!-- Información personal --}}
          <div class="tq-section-box" style="margin-bottom:0;">
            <div class="tq-section-header">{{localize "TQ.Secciones.InfoPersonal"}}</div>
            <div class="tq-section-content">
              <div class="tq-info-grid">
                <div class="tq-info-field">
                  <label>{{localize "TQ.Creacion.edad"}}</label>
                  <input type="number" name="system.edad" value="{{system.edad}}" min="0" />
                </div>
                <div class="tq-info-field">
                  <label>{{localize "TQ.Creacion.religion"}}</label>
                  <input type="text" name="system.religion" value="{{system.religion}}" />
                </div>
                <div class="tq-info-field full tq-info-fila-triple">
                  <div class="tq-info-field">
                    <label>{{localize "TQ.Actor.EntornoLabel"}}</label>
                    {{#if items.entorno}}
                    <span class="tq-origen-nombre">{{items.entorno.name}}</span>
                    {{else}}
                    <span class="tq-origen-vacio">—</span>
                    {{/if}}
                  </div>
                  <div class="tq-info-field">
                    <label>{{localize "TQ.Actor.OrigenEtnicoLabel"}}</label>
                    {{#if items.origen}}
                    <span class="tq-origen-nombre">{{items.origen.name}}</span>
                    {{else}}
                    <span class="tq-origen-vacio">—</span>
                    {{/if}}
                  </div>
                  <div class="tq-info-field">
                    <label>{{localize "TQ.Actor.ProfesionLabel"}}</label>
                    {{#if items.profesion}}
                    <span class="tq-origen-nombre">{{items.profesion.name}}</span>
                    {{else}}
                    <span class="tq-origen-vacio">—</span>
                    {{/if}}
                  </div>
                </div>
                <div class="tq-info-field full tq-info-fila-triple">
                  <div class="tq-info-field">
                    <label>{{localize "TQ.Idioma.IdiomaNativo"}}</label>
                    <input type="text" name="system.habilidades.idioma1.nombre"
                           value="{{system.habilidades.idioma1.nombre}}" placeholder="—" />
                  </div>
                  <div class="tq-info-field">
                    <label>{{localize "TQ.Idioma.Idioma2"}}</label>
                    <input type="text" name="system.habilidades.idioma2.nombre"
                           value="{{system.habilidades.idioma2.nombre}}" placeholder="—" />
                  </div>
                  <div class="tq-info-field">
                    <label>{{localize "TQ.Idioma.Idioma3"}}</label>
                    <input type="text" name="system.habilidades.idioma3.nombre"
                           value="{{system.habilidades.idioma3.nombre}}" placeholder="—" />
                  </div>
                </div>
                <div class="tq-info-field full">
                  <label>{{localize "TQ.Creacion.trasfondo"}}</label>
                  <textarea name="system.trasfondo" rows="4">{{system.trasfondo}}</textarea>
                </div>
                <div class="tq-info-field full">
                  <label>{{localize "TQ.Creacion.descripcionFisica"}}</label>
                  <textarea name="system.descripcionFisica" rows="4">{{system.descripcionFisica}}</textarea>
                </div>
              </div>
            </div>
          </div>

          {{!-- Ventajas y desventajas --}}
          <div class="tq-section-box" style="margin-bottom:0;">
            <div class="tq-section-header">
              <span>{{localize "TQ.Secciones.VentajasDesventajas"}}</span>
              <a class="item-create" data-tipo="ventaja"><i class="fas fa-plus"></i></a>
            </div>
            <ul class="ventajas-list">
              {{#each items.ventajas as |vent|}}
              <li data-item-id="{{vent.id}}" class="ventaja-item tipo-{{vent.system.tipo}}">
                <strong>{{vent.name}}</strong>
                {{#if vent.system.coste}}
                  <span class="coste">({{vent.system.coste}} PP)</span>
                {{/if}}
                <span class="efecto">{{vent.system.efecto}}</span>
                <span class="item-controls">
                  <a class="item-edit" data-item-id="{{vent.id}}"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" data-item-id="{{vent.id}}"><i class="fas fa-trash"></i></a>
                </span>
              </li>
              {{/each}}
            </ul>
          </div>

          {{!-- Rasgos sobrenaturales y sociales --}}
          {{#if (or items.rasgos.length true)}}
          <div class="tq-section-box" style="margin-bottom:0;margin-top:4px;">
            <div class="tq-section-header">
              <span>{{localize "TQ.Secciones.Rasgos"}}</span>
              <a class="item-create" data-tipo="rasgo"><i class="fas fa-plus"></i></a>
            </div>
            <ul class="ventajas-list">
              {{#each items.rasgos as |r|}}
              <li data-item-id="{{r.id}}" class="ventaja-item tipo-{{r.system.tipo}}">
                <strong>{{r.name}}</strong>
                {{#if r.system.coste}}
                  <span class="coste">({{r.system.coste}} PP)</span>
                {{/if}}
                <span class="efecto">{{r.system.efecto}}</span>
                <span class="item-controls">
                  <a class="item-edit" data-item-id="{{r.id}}"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" data-item-id="{{r.id}}"><i class="fas fa-trash"></i></a>
                </span>
              </li>
              {{/each}}
            </ul>
          </div>
          {{/if}}

          {{!-- Rasgos de personalidad --}}
          <div class="tq-section-box" style="margin-bottom:0;margin-top:4px;">
            <div class="tq-section-header">{{localize "TQ.Secciones.RasgosPersonalidad"}}</div>
            <div class="tq-section-content">
              <div class="rasgos-grid">
                <div class="rasgos-col">
                  <div class="rasgos-col-title rasgo-pos-title">{{localize "TQ.Rasgos.Positivos"}}</div>
                  <div class="rasgo-fila">
                    <input type="text" name="system.rasgoPos1" value="{{system.rasgoPos1}}" placeholder="{{localize "TQ.Placeholders.RasgoPos1"}}" class="rasgo-input rasgo-pos" />
                    <a class="tq-circulo toggle-rasgo-usada {{#if system.rasgoPos1Usada}}marcado{{/if}}" data-campo="rasgoPos1Usada" title="Marcar uso"></a>
                  </div>
                  <div class="rasgo-fila">
                    <input type="text" name="system.rasgoPos2" value="{{system.rasgoPos2}}" placeholder="{{localize "TQ.Placeholders.RasgoPos2"}}" class="rasgo-input rasgo-pos" />
                    <a class="tq-circulo toggle-rasgo-usada {{#if system.rasgoPos2Usada}}marcado{{/if}}" data-campo="rasgoPos2Usada" title="Marcar uso"></a>
                  </div>
                  <div class="rasgo-fila">
                    <input type="text" name="system.rasgoPos3" value="{{system.rasgoPos3}}" placeholder="{{localize "TQ.Placeholders.RasgoPos3"}}" class="rasgo-input rasgo-pos rasgo-extra" />
                    <a class="tq-circulo toggle-rasgo-usada {{#if system.rasgoPos3Usada}}marcado{{/if}}" data-campo="rasgoPos3Usada" title="Marcar uso"></a>
                  </div>
                </div>
                <div class="rasgos-col">
                  <div class="rasgos-col-title rasgo-neg-title">{{localize "TQ.Rasgos.Negativos"}}</div>
                  <div class="rasgo-fila">
                    <input type="text" name="system.rasgoNeg1" value="{{system.rasgoNeg1}}" placeholder="{{localize "TQ.Placeholders.RasgoNeg1"}}" class="rasgo-input rasgo-neg" />
                    <a class="tq-circulo toggle-rasgo-usada {{#if system.rasgoNeg1Usada}}marcado{{/if}}" data-campo="rasgoNeg1Usada" title="Marcar uso"></a>
                  </div>
                  <div class="rasgo-fila">
                    <input type="text" name="system.rasgoNeg2" value="{{system.rasgoNeg2}}" placeholder="{{localize "TQ.Placeholders.RasgoNeg2"}}" class="rasgo-input rasgo-neg" />
                    <a class="tq-circulo toggle-rasgo-usada {{#if system.rasgoNeg2Usada}}marcado{{/if}}" data-campo="rasgoNeg2Usada" title="Marcar uso"></a>
                  </div>
                  <div class="rasgo-fila">
                    <input type="text" name="system.rasgoNeg3" value="{{system.rasgoNeg3}}" placeholder="{{localize "TQ.Placeholders.RasgoNeg3"}}" class="rasgo-input rasgo-neg rasgo-extra" />
                    <a class="tq-circulo toggle-rasgo-usada {{#if system.rasgoNeg3Usada}}marcado{{/if}}" data-campo="rasgoNeg3Usada" title="Marcar uso"></a>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>{{!-- /col der --}}

      </div>{{!-- /fila principal --}}

      {{!-- FILA INFERIOR: ancho completo --}}
      <div style="display:flex;flex-direction:column;gap:4px;">

        {{!-- Guías Interpretativas --}}
        <div class="tq-section-box" style="margin-bottom:0;">
          <div class="tq-section-header">{{localize "TQ.Secciones.GuiasInterpretativas"}}</div>
          <div class="tq-section-content">
            <div class="guias-grid">
              <div class="guia-field full">
                <div style="display:flex;align-items:center;gap:6px;">
                  <label>{{localize "TQ.Creacion.motivacion"}}</label>
                  <a class="tq-circulo toggle-rasgo-usada {{#if system.motivacionUsada}}marcado{{/if}}" data-campo="motivacionUsada" title="Marcar uso"></a>
                </div>
                <input type="text" name="system.motivacion" value="{{system.motivacion}}" />
              </div>
              <div class="guia-field full">
                <div style="display:flex;align-items:center;gap:6px;">
                  <label>{{localize "TQ.Creacion.tuMentira"}}</label>
                  <div class="mentira-marcas">
                    <a class="tq-circulo marcar-mentira {{#if (tq-gt system.tuMentiraMarcas 0)}}marcado{{/if}}" data-marca="1" title="Marca 1 de La Mentira"></a>
                    <a class="tq-circulo marcar-mentira {{#if (tq-gt system.tuMentiraMarcas 1)}}marcado{{/if}}" data-marca="2" title="Marca 2 de La Mentira"></a>
                    <a class="tq-circulo marcar-mentira {{#if (tq-gt system.tuMentiraMarcas 2)}}marcado{{/if}}" data-marca="3" title="Marca 3 de La Mentira"></a>
                    <a class="tq-circulo marcar-mentira {{#if (tq-gt system.tuMentiraMarcas 3)}}marcado{{/if}}" data-marca="4" title="Marca 4 de La Mentira"></a>
                    <a class="tq-circulo marcar-mentira {{#if (tq-gt system.tuMentiraMarcas 4)}}marcado{{/if}}" data-marca="5" title="Marca 5 → +1 Destino, +5 PX"></a>
                  </div>
                </div>
                <input type="text" name="system.tuMentira" value="{{system.tuMentira}}" />
              </div>
              <div class="guia-field">
                <label>{{localize "TQ.Creacion.pasionAmor"}}</label>
                <div class="guia-pasion-fila">
                  <input type="text" name="system.pasionAmor" value="{{system.pasionAmor}}" />
                  <a class="activar-pasion {{#if pasionAmorActiva}}pasion-activa{{/if}} {{#if system.pasionAmorUsada}}pasion-usada{{/if}}" data-tipo="amor" title="{{#if system.pasionAmorUsada}}Pasión ya usada esta escena{{else}}Activar Pasión (Amor){{/if}}"><i class="fas fa-fire"></i></a>
                  <a class="tq-circulo toggle-pasion-usada {{#if system.pasionAmorUsada}}marcado{{/if}}" data-campo="pasionAmorUsada" title="Marcar/desmarcar uso de pasión"></a>
                </div>
              </div>
              <div class="guia-field">
                <label>{{localize "TQ.Creacion.pasionOdio"}}</label>
                <div class="guia-pasion-fila">
                  <input type="text" name="system.pasionOdio" value="{{system.pasionOdio}}" />
                  <a class="activar-pasion {{#if pasionOdioActiva}}pasion-activa{{/if}} {{#if system.pasionOdioUsada}}pasion-usada{{/if}}" data-tipo="odio" title="{{#if system.pasionOdioUsada}}Pasión ya usada esta escena{{else}}Activar Pasión (Odio){{/if}}"><i class="fas fa-fire"></i></a>
                  <a class="tq-circulo toggle-pasion-usada {{#if system.pasionOdioUsada}}marcado{{/if}}" data-campo="pasionOdioUsada" title="Marcar/desmarcar uso de pasión"></a>
                </div>
              </div>
              <div class="guia-field full">
                <a class="resetear-pasiones" title="Resetear marcas de pasión (nueva escena)" style="visibility:hidden;"></a>
              </div>
            </div>
          </div>
        </div>

        {{!-- Notas --}}
        <div class="tq-section-box" style="margin-bottom:0;">
          <div class="tq-section-header">{{localize "TQ.General.Notas"}}</div>
          <div class="tq-section-content">
            <textarea class="tq-notas" name="system.descripcion" rows="4">{{system.descripcion}}</textarea>
          </div>
        </div>

      </div>{{!-- /fila inferior --}}

      {{!-- Espaciador inferior --}}
      <div style="height:40px;background:var(--tq-parchment);border:none;"></div>

    </div>{{!-- /tab hoja2 --}}

  </section>{{!-- /sheet-body --}}

</div>
