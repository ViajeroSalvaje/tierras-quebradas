<div class="{{cssClass}}" autocomplete="off" style="display:flex;flex-direction:column;height:100%;width:100%;">

  {{!-- CABECERA --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Nombre del personaje" />
      </h1>
      <div class="header-info">
        {{#if items.especie}}
        <div class="field-group especie-slot activa">
          <label>Especie</label>
          <span class="especie-nombre">{{items.especie.name}}</span>
        </div>
        {{else}}
        <div class="field-group especie-slot vacia">
          <label>Especie</label>
          <span class="especie-vacia">Arrastra una especie aquí</span>
        </div>
        {{/if}}
        {{#if items.origen}}
        <div class="field-group especie-slot activa">
          <label>Origen</label>
          <span class="especie-nombre">{{items.origen.name}}</span>
        </div>
        {{else}}
        <div class="field-group especie-slot vacia">
          <label>Origen</label>
          <span class="especie-vacia">Arrastra un origen aquí</span>
        </div>
        {{/if}}
        {{#if items.profesion}}
        <div class="field-group especie-slot activa">
          <label>Profesión</label>
          <span class="especie-nombre">{{items.profesion.name}}</span>
        </div>
        {{else}}
        <div class="field-group especie-slot vacia">
          <label>Profesión</label>
          <span class="especie-vacia">Arrastra una profesión aquí</span>
        </div>
        {{/if}}
        <div class="field-group">
          <label>{{localize "TQ.Creacion.edad"}}</label>
          <span style="width:50px;display:inline-block;">{{system.edad}}</span>
        </div>
        <div class="field-group">
          <label>PP</label>
          <input type="number" name="system.puntosPP" value="{{system.puntosPP}}" style="width:45px;" />
        </div>
      </div>
    </div>
  </header>

  {{!-- PESTAÑAS --}}
  <nav class="sheet-tabs" data-group="primary">
    <a class="item" data-tab="hoja1">Personaje</a>
    <a class="item" data-tab="combate">Combate y Equipo</a>
    <a class="item" data-tab="magia">Magia</a>
    <a class="item" data-tab="hoja2">Trasfondo</a>
  </nav>

  <section class="sheet-body">

    {{!-- ══════════════════════════════════════════════════════════════
         TAB HOJA 1 — PERSONAJE
    ══════════════════════════════════════════════════════════════ --}}
    <div class="tab" data-tab="hoja1">

      {{!-- Fila superior: izquierda (características) + derecha (bases + destino) --}}
      <div class="tq-top-row">

        {{!-- IZQUIERDA: Características --}}
        <div class="tq-top-izq">

          {{!-- Características principales --}}
          <div class="tq-section-box">
            <div class="tq-section-header">Características</div>
            <div class="tq-section-content">
              <div class="caract-grid">
                <div class="caract-item">
                  <span class="caract-etiqueta tirar-caracteristica" data-caracteristica="cuerpo">CUE</span>
                  <div class="caract-circulo">
                    <input type="number" name="system.caracteristicas.cuerpo.valor"
                           value="{{system.caracteristicas.cuerpo.valor}}" min="1" max="20" />
                  </div>
                  <span style="font-size:10px;color:var(--tq-text-dim);">Cuerpo</span>
                </div>
                <div class="caract-item">
                  <span class="caract-etiqueta tirar-caracteristica" data-caracteristica="mente">MEN</span>
                  <div class="caract-circulo">
                    <input type="number" name="system.caracteristicas.mente.valor"
                           value="{{system.caracteristicas.mente.valor}}" min="1" max="20" />
                  </div>
                  <span style="font-size:10px;color:var(--tq-text-dim);">Mente</span>
                </div>
                <div class="caract-item">
                  <span class="caract-etiqueta tirar-caracteristica" data-caracteristica="espiritu">ESP</span>
                  <div class="caract-circulo">
                    <input type="number" name="system.caracteristicas.espiritu.valor"
                           value="{{system.caracteristicas.espiritu.valor}}" min="1" max="20" />
                  </div>
                  <span style="font-size:10px;color:var(--tq-text-dim);">Espíritu</span>
                </div>
              </div>
              {{!-- ATR y TAM --}}
              <div class="caract-sec-row">
                <div class="caract-sec-item">
                  <span class="caract-sec-label">ATR</span>
                  <div class="caract-sec-circle">
                    <input type="number" name="system.caracteristicas.atractivo.valor"
                           value="{{system.caracteristicas.atractivo.valor}}" min="-5" max="10" />
                  </div>
                  <span style="font-size:9px;color:var(--tq-text-dim);">Atractivo</span>
                </div>
                <div class="caract-sec-item">
                  <span class="caract-sec-label">TAM</span>
                  <div class="caract-sec-circle">
                    <input type="number" name="system.caracteristicas.tamano.valor"
                           value="{{system.caracteristicas.tamano.valor}}" min="-3" max="10" />
                  </div>
                  <span style="font-size:9px;color:var(--tq-text-dim);">Tamaño</span>
                </div>
              </div>
              {{!-- Derivadas --}}
              <div class="derivadas-row">
                <div class="derivada-item">
                  <span class="derivada-label">Fuerza</span>
                  <span class="derivada-value">{{system.derivadas.fuerza.valor}}</span>
                </div>
                <div class="derivada-item">
                  <span class="derivada-label">MD 1M</span>
                  <span class="derivada-value">{{system.derivadas.mDano1m.valor}}</span>
                </div>
                <div class="derivada-item">
                  <span class="derivada-label">MD 2M</span>
                  <span class="derivada-value">{{system.derivadas.mDano2m.valor}}</span>
                </div>
              </div>
            </div>
          </div>

        </div>{{!-- /tq-top-izq --}}

        {{!-- DERECHA: Bases + Destino + Fortuna + Estorbo --}}
        <div class="tq-top-der">

          {{!-- Bases de habilidades --}}
          <div class="tq-section-box" style="flex:1;">
            <div class="tq-section-header">Bases de Habilidades</div>
            <div class="tq-section-content">
              <table class="bases-table">
                <tbody>
                  <tr>
                    <td class="base-nombre">Agilidad</td>
                    <td class="base-valor">{{system.bases.agilidad.valor}}</td>
                    <td class="base-formula">CUE − TAM</td>
                  </tr>
                  <tr>
                    <td class="base-nombre">Comunicación</td>
                    <td class="base-valor">{{system.bases.comunicacion.valor}}</td>
                    <td class="base-formula">ESP + ATR</td>
                  </tr>
                  <tr>
                    <td class="base-nombre">Cultura</td>
                    <td class="base-valor">{{system.bases.cultura.valor}}</td>
                    <td class="base-formula">MEN</td>
                  </tr>
                  <tr>
                    <td class="base-nombre">Hechicería</td>
                    <td class="base-valor">{{system.bases.hechiceria.valor}}</td>
                    <td class="base-formula">(MEN+ESP)/3</td>
                  </tr>
                  <tr>
                    <td class="base-nombre">Percepción</td>
                    <td class="base-valor">{{system.bases.percepcion.valor}}</td>
                    <td class="base-formula">(MEN+ESP)/2</td>
                  </tr>
                  <tr>
                    <td class="base-nombre">Técnica</td>
                    <td class="base-valor">{{system.bases.tecnica.valor}}</td>
                    <td class="base-formula">(MEN+CUE)/2</td>
                  </tr>
                  <tr>
                    <td class="base-nombre">Vigor</td>
                    <td class="base-valor">{{system.bases.vigor.valor}}</td>
                    <td class="base-formula">CUE</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          {{!-- Destino + Fortuna + Carga y Estorbo --}}
          <div class="tq-top-der-recursos">
            {{!-- Destino --}}
            <div class="tq-section-box">
              <div class="tq-section-header">Destino</div>
              <div class="tq-section-content">
                <div class="destino-box">
                  <label>Actual</label>
                  <input type="number" name="system.destino.actual"
                         value="{{system.destino.actual}}" min="0" max="{{system.destino.max}}" />
                  <label>/ Máx</label>
                  <input type="number" name="system.destino.max"
                         value="{{system.destino.max}}" min="0" style="width:35px;" />
                </div>
              </div>
            </div>
            {{!-- Fortuna --}}
            <div class="tq-section-box">
              <div class="tq-section-header">Fortuna</div>
              <div class="tq-section-content">
                <div class="fortuna-row">
                  <button type="button" class="usar-fortuna" title="Gastar Fortuna">−</button>
                  <div class="fortuna-pips">
                    {{#tq-rango 1 system.fortuna.max}}
                    <span class="fortuna-pip {{#if (tq-gt (tq-add ../system.fortuna.actual 1) this)}}lleno{{/if}}">●</span>
                    {{/tq-rango}}
                  </div>
                  <button type="button" class="recuperar-fortuna" title="Recuperar Fortuna">+</button>
                </div>
              </div>
            </div>
            {{!-- Carga y Estorbo --}}
            <div class="tq-section-box">
              <div class="tq-section-header">Carga y Estorbo</div>
              <div class="tq-section-content" style="display:flex;align-items:center;justify-content:center;">
                <div class="estorbo-row">
                  <div class="estorbo-field">
                    <label>Carga</label>
                    <span class="estorbo-valor">{{system.carga.valor}}</span>
                  </div>
                  <div class="estorbo-field">
                    <label>Estorbo</label>
                    <span class="estorbo-valor">{{system.estorbo.valor}}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>{{!-- /tq-top-der-recursos --}}

        </div>{{!-- /tq-top-der --}}
      </div>{{!-- /tq-top-row --}}

      {{!-- PUNTOS DE VIDA (ancho completo) --}}
      <div class="tq-section-box">
        <div class="tq-section-header">Puntos de Vida</div>
        <div class="tq-section-content">
          <div class="pv-main-row">
            <span class="pv-label">PV</span>
            <input type="number" name="system.salud.pvActual.valor"
                   value="{{system.salud.pvActual.valor}}"
                   class="pv-input {{tq-pv-estado system.salud.pvActual.valor system.salud.pvMax.valor}}" />
            <span class="pv-sep">/</span>
            <span class="pv-max">{{system.salud.pvMax.valor}}</span>

            <span class="estados-row">
              <label class="estado-check {{#if system.salud.debilitado}}activo{{/if}}">
                <input type="checkbox" name="system.salud.debilitado" {{checked system.salud.debilitado}} />
                Debilitado
              </label>
              <label class="estado-check {{#if system.salud.incapacitado}}activo{{/if}}">
                <input type="checkbox" name="system.salud.incapacitado" {{checked system.salud.incapacitado}} />
                Incapacitado
              </label>
              <label class="estado-check {{#if system.salud.sanando}}activo{{/if}}">
                <input type="checkbox" name="system.salud.sanando" {{checked system.salud.sanando}} />
                Sanando
              </label>
              <label class="estado-check estado-danger {{#if system.salud.desangre}}activo{{/if}}">
                <input type="checkbox" name="system.salud.desangre" {{checked system.salud.desangre}} />
                Desangre
              </label>
              <label class="estado-check estado-danger {{#if system.salud.dolorExtremo}}activo{{/if}}">
                <input type="checkbox" name="system.salud.dolorExtremo" {{checked system.salud.dolorExtremo}} />
                Dolor Extremo
              </label>
              <label class="estado-check {{#if system.salud.piernaInutilizada}}activo{{/if}}">
                <input type="checkbox" name="system.salud.piernaInutilizada" {{checked system.salud.piernaInutilizada}} />
                Pierna
              </label>
              <label class="estado-check {{#if system.salud.brazoInutilizado}}activo{{/if}}">
                <input type="checkbox" name="system.salud.brazoInutilizado" {{checked system.salud.brazoInutilizado}} />
                Brazo
              </label>
            </span>
          </div>
        </div>
      </div>

      {{!-- HERIDAS --}}
      <div class="tq-section-box">
        <div class="tq-section-header">Heridas</div>
        <div class="tq-section-content">
          <div class="heridas-cabecera">
            <div class="pv-umbrales">
              <span title="Umbral de Rasguño">R: {{system.salud.pvRagunos.valor}}</span>
              <span title="Umbral de Herida Leve">HL: {{system.salud.pvLeve.valor}}</span>
              <span title="Umbral de Herida Grave">HG: {{system.salud.pvGrave.valor}}</span>
            </div>
            <div class="heridas-leves-check">
              <span class="heridas-leves-label">Heridas Leves</span>
              <input type="checkbox" class="herida-leve-check" name="system.salud.heridasLeves1" {{checked system.salud.heridasLeves1}} />
              <input type="checkbox" class="herida-leve-check" name="system.salud.heridasLeves2" {{checked system.salud.heridasLeves2}} />
            </div>
            <div class="heridas-leves-check">
              <span class="heridas-leves-label">Heridas Graves</span>
              <input type="checkbox" class="herida-leve-check" name="system.salud.heridasGraves1" {{checked system.salud.heridasGraves1}} />
              <input type="checkbox" class="herida-leve-check" name="system.salud.heridasGraves2" {{checked system.salud.heridasGraves2}} />
            </div>
          </div>
        </div>
      </div>

      {{!-- HABILIDADES en 3 columnas --}}
      <div class="tq-section-box">
        <div class="tq-section-header">
          Habilidades
          <button type="button" class="tq-btn fin-sesion-px" title="Dar 1 PX a cada habilidad marcada y borrar marcas">Fin de Sesión</button>
          <button type="button" class="tq-btn fin-aventura-px" title="Repartir PX libres al finalizar la aventura">Fin de Aventura</button>
        </div>
        <div class="tq-section-content" style="padding:2px;">
          <div class="skills-grid">

            {{!-- Columna 1 --}}
            <div class="skills-col">
              {{#each col1 as |entry|}}
              <div class="skill-row">
                <a class="skill-circle toggle-exito {{#if entry.hab.exito}}marcado{{/if}}"
                   data-habilidad="{{entry.key}}" title="Marcar/desmarcar éxito"></a>
                {{#if entry.esIdioma}}
                <a class="skill-name tirar-habilidad" data-habilidad="{{entry.key}}"
                   title="Tirar {{#if entry.hab.nombre}}{{entry.hab.nombre}}{{else}}Idioma{{/if}}">
                  {{#if entry.hab.nombre}}{{entry.hab.nombre}}
                  {{else}}<em style="color:var(--tq-text-dim);">—</em>{{/if}}
                </a>
                {{else}}
                <a class="skill-name tirar-habilidad" data-habilidad="{{entry.key}}"
                   title="Tirar {{localize (concat 'TQ.Habilidades.' entry.key)}}">
                  {{localize (concat "TQ.Habilidades." entry.key)}}
                </a>
                {{/if}}
                <span class="skill-px-display" data-habilidad="{{entry.key}}" title="PX acumulados — clic para editar">({{entry.hab.px}})</span>
                <span class="skill-base-tag">{{tq-base-abrev entry.hab.base}}</span>
                <span class="skill-total">{{tq-habilidad-total entry.hab @root.system.bases @root.system.estorbo.valor}}</span>
                <span class="skill-nivel">
                  <input type="number" name="system.habilidades.{{entry.key}}.nivel"
                         value="{{entry.hab.nivel}}" min="0" />
                </span>
              </div>
              {{/each}}
            </div>

            {{!-- Columna 2 --}}
            <div class="skills-col">
              {{#each col2 as |entry|}}
              <div class="skill-row">
                <a class="skill-circle toggle-exito {{#if entry.hab.exito}}marcado{{/if}}"
                   data-habilidad="{{entry.key}}" title="Marcar/desmarcar éxito"></a>
                {{#if entry.esIdioma}}
                <a class="skill-name tirar-habilidad" data-habilidad="{{entry.key}}"
                   title="Tirar {{#if entry.hab.nombre}}{{entry.hab.nombre}}{{else}}Idioma{{/if}}">
                  {{#if entry.hab.nombre}}{{entry.hab.nombre}}
                  {{else}}<em style="color:var(--tq-text-dim);">—</em>{{/if}}
                </a>
                {{else}}
                <a class="skill-name tirar-habilidad" data-habilidad="{{entry.key}}"
                   title="Tirar {{localize (concat 'TQ.Habilidades.' entry.key)}}">
                  {{localize (concat "TQ.Habilidades." entry.key)}}
                </a>
                {{/if}}
                <span class="skill-px-display" data-habilidad="{{entry.key}}" title="PX acumulados — clic para editar">({{entry.hab.px}})</span>
                <span class="skill-base-tag">{{tq-base-abrev entry.hab.base}}</span>
                <span class="skill-total">{{tq-habilidad-total entry.hab @root.system.bases @root.system.estorbo.valor}}</span>
                <span class="skill-nivel">
                  <input type="number" name="system.habilidades.{{entry.key}}.nivel"
                         value="{{entry.hab.nivel}}" min="0" />
                </span>
              </div>
              {{/each}}
            </div>

            {{!-- Columna 3 --}}
            <div class="skills-col">
              {{#each col3 as |entry|}}
              <div class="skill-row">
                <a class="skill-circle toggle-exito {{#if entry.hab.exito}}marcado{{/if}}"
                   data-habilidad="{{entry.key}}" title="Marcar/desmarcar éxito"></a>
                {{#if entry.esIdioma}}
                <a class="skill-name tirar-habilidad" data-habilidad="{{entry.key}}"
                   title="Tirar {{#if entry.hab.nombre}}{{entry.hab.nombre}}{{else}}Idioma{{/if}}">
                  {{#if entry.hab.nombre}}{{entry.hab.nombre}}
                  {{else}}<em style="color:var(--tq-text-dim);">—</em>{{/if}}
                </a>
                {{else}}
                <a class="skill-name tirar-habilidad" data-habilidad="{{entry.key}}"
                   title="Tirar {{localize (concat 'TQ.Habilidades.' entry.key)}}">
                  {{localize (concat "TQ.Habilidades." entry.key)}}
                </a>
                {{/if}}
                <span class="skill-px-display" data-habilidad="{{entry.key}}" title="PX acumulados — clic para editar">({{entry.hab.px}})</span>
                <span class="skill-base-tag">{{tq-base-abrev entry.hab.base}}</span>
                <span class="skill-total">{{tq-habilidad-total entry.hab @root.system.bases @root.system.estorbo.valor}}</span>
                <span class="skill-nivel">
                  <input type="number" name="system.habilidades.{{entry.key}}.nivel"
                         value="{{entry.hab.nivel}}" min="0" />
                </span>
              </div>
              {{/each}}
            </div>

          </div>{{!-- /skills-grid --}}
        </div>
      </div>

      {{!-- Espaciador inferior --}}
      <div style="height:40px;background:var(--tq-parchment);border:none;"></div>

    </div>{{!-- /tab hoja1 --}}


    {{!-- ══════════════════════════════════════════════════════════════
         TAB COMBATE Y EQUIPO
    ══════════════════════════════════════════════════════════════ --}}
    <div class="tab" data-tab="combate">

      {{!-- DINERO --}}
      <div class="tq-dinero-row">
        <label class="tq-dinero-label">Monedas de bronce (mb)</label>
        <input type="number" name="system.dinero" value="{{system.dinero}}" min="0" class="tq-dinero-input" />
      </div>

      {{!-- ARMAS --}}
      <div class="tq-section-box">
        <div class="tq-section-header">
          <span>Armas</span>
          <a class="item-create" data-tipo="arma" title="Añadir arma"><i class="fas fa-plus"></i></a>
        </div>
        <div class="tq-section-content" style="padding:2px;">
          <table class="armas-table">
            <thead>
              <tr>
                <th></th>
                <th>Nombre</th>
                <th>Hab. (total)</th>
                <th>Daño</th>
                <th>MD</th>
                <th>Alcance</th>
                <th>Carga</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each items.armas as |arma|}}
              <tr data-item-id="{{arma.item.id}}">
                <td>
                  <a class="tirar-arma" data-item-id="{{arma.item.id}}" title="Tirar {{arma.item.name}}">
                    <i class="fas fa-dice-d10"></i>
                  </a>
                </td>
                <td>{{arma.item.name}}</td>
                <td class="arma-hab">
                  <span class="arma-hab-clave">{{arma.item.system.habilidad}}</span>
                  {{#if arma.habTotal}}<span class="arma-hab-total">({{arma.habTotal}})</span>{{/if}}
                </td>
                <td>{{arma.item.system.danoArma}}</td>
                <td>{{arma.mdStr}}</td>
                <td>{{arma.item.system.alcance}}</td>
                <td>{{arma.item.system.carga}}</td>
                <td class="item-controls">
                  <a class="item-edit" data-item-id="{{arma.item.id}}" title="Editar"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" data-item-id="{{arma.item.id}}" title="Eliminar"><i class="fas fa-trash"></i></a>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>

      {{!-- PROTECCIÓN + MD --}}
      <div class="tq-bottom-row">

        {{!-- Protección --}}
        <div class="tq-section-box" style="flex:1;min-width:130px;">
          <div class="tq-section-header">Protección</div>
          <div class="tq-section-content">
            {{#each items.armaduras as |arm|}}
            <div class="prot-row" data-item-id="{{arm.id}}">
              <span style="flex:1;font-size:14px;">{{arm.name}}</span>
              <span class="prot-valor">{{arm.system.proteccion}}</span>
              <span class="item-controls" style="margin-left:4px;">
                <a class="item-edit" data-item-id="{{arm.id}}"><i class="fas fa-edit"></i></a>
                <a class="item-delete" data-item-id="{{arm.id}}"><i class="fas fa-trash"></i></a>
              </span>
            </div>
            {{/each}}
            <a class="item-create" data-tipo="armadura"
               style="font-size:10px;color:var(--tq-teal);cursor:pointer;">
              <i class="fas fa-plus"></i> Añadir
            </a>
          </div>
        </div>

        {{!-- Mod. Daño --}}
        <div class="tq-section-box" style="flex:0 0 auto;min-width:100px;">
          <div class="tq-section-header">Mod. al Daño</div>
          <div class="tq-section-content">
            <div class="md-field">
              <span>1M:</span>
              <strong>{{system.derivadas.mDano1m.valor}}</strong>
            </div>
            <div class="md-field">
              <span>2M:</span>
              <strong>{{system.derivadas.mDano2m.valor}}</strong>
            </div>
          </div>
        </div>

      </div>{{!-- /tq-bottom-row --}}

      {{!-- Tabla de Lesiones --}}
      <div class="tq-bottom-row" style="margin-top:6px;">
        <div class="tq-section-box" style="flex:1;">
          <div class="tq-section-header">Herida Grave</div>
          <div class="tq-section-content" style="padding:6px 8px;">
            <a class="tirar-lesion tq-btn-roll" title="Tirar en la Tabla de Lesiones (1d20)">
              <i class="fas fa-dice-d20"></i> Tabla de Lesiones
            </a>
          </div>
        </div>
      </div>

      {{!-- Espaciador inferior --}}
      <div style="height:40px;background:var(--tq-parchment);border:none;"></div>

    </div>{{!-- /tab combate --}}


    {{!-- ══════════════════════════════════════════════════════════════
         TAB MAGIA
    ══════════════════════════════════════════════════════════════ --}}
    <div class="tab" data-tab="magia">

      {{!-- Puntos de Magia --}}
      <div class="tq-section-box">
        <div class="tq-section-header">Puntos de Magia</div>
        <div class="tq-section-content">
          <div class="pm-row">
            <label>PM</label>
            <input type="number" name="system.hechiceria.pmActual"
                   value="{{system.hechiceria.pmActual}}" min="0" />
            <span class="pm-sep">/</span>
            <span class="estorbo-valor">{{system.hechiceria.pmMax}}</span>
            <span class="pm-sep" style="margin:0 4px;">·</span>
            <label>Esp. Consagrado</label>
            <input type="number" name="system.hechiceria.espirituConsagrado"
                   value="{{system.hechiceria.espirituConsagrado}}" min="0" />
            <span class="pm-sep" style="margin:0 4px;">·</span>
            <label>Base Hech.</label>
            <strong style="color:var(--tq-teal-dark);font-size:17px;">{{system.bases.hechiceria.valor}}</strong>
            <button type="button" class="tq-btn recuperar-pm" style="margin-left:8px;" title="Recuperar PM durmiendo"><i class="fas fa-moon"></i></button>
          </div>
        </div>
      </div>

      {{!-- Verbos y Esferas en dos columnas --}}
      <div style="display:flex;gap:6px;">

        {{!-- Verbos --}}
        <div class="tq-section-box" style="flex:1;">
          <div class="tq-section-header">{{localize "TQ.Hechiceria.Verbos"}}</div>
          <div class="tq-section-content" style="padding:2px 4px;">
            <div class="hechiceria-lista">
              {{#each system.hechiceria.verbos as |val verbo|}}
              <div class="hechiceria-row">
                <span class="hechiceria-circle"></span>
                <span class="hechiceria-nombre">{{localize (concat "TQ.Hechiceria." verbo)}}</span>
                <span class="skill-total">{{tq-add @root.system.bases.hechiceria.valor val}}</span>
                <span class="hechiceria-valor">
                  <input type="number" name="system.hechiceria.verbos.{{verbo}}" value="{{val}}" min="0" />
                </span>
              </div>
              {{/each}}
            </div>
          </div>
        </div>

        {{!-- Esferas --}}
        <div class="tq-section-box" style="flex:1;">
          <div class="tq-section-header">{{localize "TQ.Hechiceria.Esferas"}}</div>
          <div class="tq-section-content" style="padding:2px 4px;">
            <div class="hechiceria-lista">
              {{#each system.hechiceria.esferas as |val esfera|}}
              <div class="hechiceria-row">
                <span class="hechiceria-circle"></span>
                <span class="hechiceria-nombre">{{localize (concat "TQ.Hechiceria." esfera)}}</span>
                <span class="skill-total">{{tq-add @root.system.bases.hechiceria.valor val}}</span>
                <span class="hechiceria-valor">
                  <input type="number" name="system.hechiceria.esferas.{{esfera}}" value="{{val}}" min="0" />
                </span>
              </div>
              {{/each}}
            </div>
          </div>
        </div>

      </div>

      {{!-- Hechizos --}}
      <div class="tq-section-box">
        <div class="tq-section-header">
          <span>Hechizos</span>
          <a class="item-create" data-tipo="hechizo"><i class="fas fa-plus"></i></a>
        </div>
        <ul class="hechizos-list">
          {{#each items.hechizos as |hech|}}
          <li class="hechizo-item" data-item-id="{{hech.id}}">
            <div class="hechizo-main">
              <span class="hechizo-nombre">{{hech.name}}</span>
              <span class="item-controls">
                <a class="tirar-hechizo btn-lanzar" data-item-id="{{hech.id}}">Lanzar</a>
                <a class="item-edit" data-item-id="{{hech.id}}"><i class="fas fa-edit"></i></a>
                <a class="item-delete" data-item-id="{{hech.id}}"><i class="fas fa-trash"></i></a>
              </span>
            </div>
            <div class="hechizo-meta">
              {{#if hech.system.verbo}}<span>{{hech.system.verbo}}{{#if hech.system.esfera}} {{hech.system.esfera}}{{/if}}</span><span class="hechizo-sep">|</span>{{/if}}
              <span>DIF. {{hech.system.dificultad}}</span>
              <span class="hechizo-sep">|</span>
              <span>PM {{hech.system.pmCoste}}{{#if (tq-gt hech.system.pmMax hech.system.pmCoste)}}-{{hech.system.pmMax}}{{/if}}</span>
              {{#if (tq-eq hech.system.duracion "instantaneo")}}<span class="hechizo-sep">|</span><span class="hechizo-badge">Inmediato</span>{{/if}}
              {{#if hech.system.requiereTiradaEspiritu}}<span class="hechizo-sep">|</span><span class="hechizo-espiritu" title="Requiere tirada enfrentada de Espíritu">⚔</span>{{/if}}
            </div>
          </li>
          {{/each}}
        </ul>
      </div>

      {{!-- Espaciador inferior --}}
      <div style="height:40px;background:var(--tq-parchment);border:none;"></div>

    </div>{{!-- /tab magia --}}


    {{!-- ══════════════════════════════════════════════════════════════
         TAB HOJA 2 — TRASFONDO
    ══════════════════════════════════════════════════════════════ --}}
    <div class="tab" data-tab="hoja2">

      {{!-- FILA PRINCIPAL: columna izq (Lealtad + Pactos + Bendiciones) y der (Info Personal + Ventajas) --}}
      <div style="display:flex;gap:6px;align-items:flex-start;margin-bottom:4px;">

        {{!-- Columna izquierda --}}
        <div style="flex:1;display:flex;flex-direction:column;gap:4px;">

          {{!-- LEALTAD --}}
          <div class="tq-section-box" style="margin-bottom:0;">
            <div class="tq-section-header">Lealtad</div>
            <div class="tq-section-content">
              <div class="lealtad-row">
                <div class="lealtad-item {{#if lealtad.alineado.caos}}lealtad-alineada{{/if}}">
                  <label>Caos</label>
                  <div class="lealtad-circulo">
                    <input type="number" name="system.lealtad.caos" value="{{system.lealtad.caos}}" min="0" />
                  </div>
                </div>
                <div class="lealtad-item {{#if lealtad.alineado.ley}}lealtad-alineada{{/if}}">
                  <label>Ley</label>
                  <div class="lealtad-circulo">
                    <input type="number" name="system.lealtad.ley" value="{{system.lealtad.ley}}" min="0" />
                  </div>
                </div>
                <div class="lealtad-item {{#if lealtad.alineado.elementos}}lealtad-alineada{{/if}}">
                  <label>Elementos</label>
                  <div class="lealtad-circulo">
                    <input type="number" name="system.lealtad.elementos" value="{{system.lealtad.elementos}}" min="0" />
                  </div>
                </div>
                <div class="lealtad-item {{#if lealtad.alineado.antepasados}}lealtad-alineada{{/if}}">
                  <label>Antepasados</label>
                  <div class="lealtad-circulo">
                    <input type="number" name="system.lealtad.antepasados" value="{{system.lealtad.antepasados}}" min="0" />
                  </div>
                </div>
              </div>
              <div class="lealtad-divina-campo">
                <label>Actitud ante lo divino</label>
                <select name="system.actitudDivina">
                  <option value="servicial"   {{selected system.actitudDivina "servicial"}}>Servicial</option>
                  <option value="atemorizado" {{selected system.actitudDivina "atemorizado"}}>Atemorizado</option>
                  <option value="pragmatico"  {{selected system.actitudDivina "pragmatico"}}>Pragmático</option>
                  <option value="rebelde"     {{selected system.actitudDivina "rebelde"}}>Rebelde</option>
                  <option value="indiferente" {{selected system.actitudDivina "indiferente"}}>Indiferente</option>
                </select>
              </div>
              <div class="lealtad-divina-campo actitud-efecto">
                {{#if (tq-eq system.actitudDivina "servicial")}}
                  <span class="actitud-desc">+2 PL gratis al finalizar sesión</span>
                  <button type="button" class="tq-btn fin-sesion-actitud">Aplicar fin de sesión</button>
                {{/if}}
                {{#if (tq-eq system.actitudDivina "atemorizado")}}
                  <span class="actitud-desc">Canjear 3 PL ↔ 1 Fortuna</span>
                  <button type="button" class="tq-btn fin-sesion-actitud">Aplicar fin de sesión</button>
                {{/if}}
                {{#if (tq-eq system.actitudDivina "pragmatico")}}
                  <span class="actitud-desc">Gastar 3 PL → 1 PE extra en habilidad marcada</span>
                  <button type="button" class="tq-btn fin-sesion-actitud">Aplicar fin de sesión</button>
                {{/if}}
                {{#if (tq-eq system.actitudDivina "rebelde")}}
                  <span class="actitud-desc">Reducir 20 PL ↔ 1 Destino</span>
                  <button type="button" class="tq-btn fin-sesion-actitud">Aplicar fin de sesión</button>
                {{/if}}
                {{#if (tq-eq system.actitudDivina "indiferente")}}
                  <span class="actitud-desc">Transferir hasta 3 PL entre religiones</span>
                  <button type="button" class="tq-btn fin-sesion-actitud">Aplicar fin de sesión</button>
                {{/if}}
              </div>
              <div class="lealtad-divina-campo">
                <button type="button" class="tq-btn cambiar-lealtad-pm">Cambiar Lealtad por PM</button>
              </div>
            </div>
          </div>

          {{!-- Pactos --}}
          <div class="tq-section-box" style="margin-bottom:0;">
            <div class="tq-section-header">
              <span>Pactos</span>
              <a class="item-create" data-tipo="pacto"><i class="fas fa-plus"></i></a>
            </div>
            <ul class="pactos-list">
              {{#each items.pactos as |pacto|}}
              <li class="pacto-item">
                <span class="pacto-dios">{{pacto.name}}</span>
                <span class="pacto-religion">({{pacto.system.religion}})</span>
                <span class="pacto-esp">{{pacto.system.espirituConsagrado}} ESP</span>
                <span class="item-controls">
                  <a class="tirar-intervencion" data-item-id="{{pacto.id}}" title="Intervención Divina"><i class="fas fa-pray"></i></a>
                  <a class="item-edit" data-item-id="{{pacto.id}}"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" data-item-id="{{pacto.id}}"><i class="fas fa-trash"></i></a>
                </span>
              </li>
              {{/each}}
            </ul>
          </div>

          {{!-- Bendiciones --}}
          <div class="tq-section-box" style="margin-bottom:0;">
            <div class="tq-section-header">
              <span>Bendiciones</span>
              <a class="item-create" data-tipo="bendicion"><i class="fas fa-plus"></i></a>
            </div>
            <ul class="bendiciones-list">
              {{#each items.bendiciones as |bend|}}
              <li class="bendicion-item tipo-{{bend.system.tipo}}">
                <span class="bend-nombre">{{bend.name}}</span>
                <span class="bend-coste">{{bend.system.coste}} ESP</span>
                {{#if (tq-eq bend.system.tipo "activa")}}
                <span class="bend-pm">{{bend.system.pmCoste}} PM</span>
                <a class="activar-bendicion" data-item-id="{{bend.id}}" title="Activar"><i class="fas fa-bolt"></i></a>
                {{/if}}
                <span class="item-controls">
                  <a class="item-edit" data-item-id="{{bend.id}}"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" data-item-id="{{bend.id}}"><i class="fas fa-trash"></i></a>
                </span>
              </li>
              {{/each}}
            </ul>
          </div>

        </div>{{!-- /col izq --}}

        {{!-- Columna derecha --}}
        <div style="flex:1;display:flex;flex-direction:column;gap:4px;">

          {{!-- Información personal --}}
          <div class="tq-section-box" style="margin-bottom:0;">
            <div class="tq-section-header">Información Personal</div>
            <div class="tq-section-content">
              <div class="info-grid">
                <div class="info-field">
                  <label>{{localize "TQ.Creacion.edad"}}</label>
                  <input type="number" name="system.edad" value="{{system.edad}}" min="0" />
                </div>
                <div class="info-field">
                  <label>{{localize "TQ.Creacion.religion"}}</label>
                  <input type="text" name="system.religion" value="{{system.religion}}" />
                </div>
                <div class="info-field full">
                  <label>{{localize "TQ.Creacion.descripcionFisica"}}</label>
                  <input type="text" name="system.descripcionFisica" value="{{system.descripcionFisica}}" />
                </div>
                <div class="info-field">
                  <label>Entorno</label>
                  {{#if items.entorno}}
                  <span class="tq-origen-nombre">{{items.entorno.name}}</span>
                  {{else}}
                  <span class="tq-origen-vacio">—</span>
                  {{/if}}
                </div>
                <div class="info-field">
                  <label>Origen Étnico</label>
                  {{#if items.origen}}
                  <span class="tq-origen-nombre">{{items.origen.name}}</span>
                  {{else}}
                  <span class="tq-origen-vacio">—</span>
                  {{/if}}
                </div>
                <div class="info-field">
                  <label>Profesión</label>
                  {{#if items.profesion}}
                  <span class="tq-origen-nombre">{{items.profesion.name}}</span>
                  {{else}}
                  <span class="tq-origen-vacio">—</span>
                  {{/if}}
                </div>
                <div class="info-field">
                  <label>Idioma nativo</label>
                  <input type="text" name="system.habilidades.idioma1.nombre"
                         value="{{system.habilidades.idioma1.nombre}}" placeholder="—" />
                </div>
                <div class="info-field">
                  <label>Idioma 2</label>
                  <input type="text" name="system.habilidades.idioma2.nombre"
                         value="{{system.habilidades.idioma2.nombre}}" placeholder="—" />
                </div>
                <div class="info-field">
                  <label>Idioma 3</label>
                  <input type="text" name="system.habilidades.idioma3.nombre"
                         value="{{system.habilidades.idioma3.nombre}}" placeholder="—" />
                </div>
                <div class="info-field full">
                  <label>{{localize "TQ.Creacion.trasfondo"}}</label>
                  <textarea name="system.trasfondo" rows="4">{{system.trasfondo}}</textarea>
                </div>
              </div>
            </div>
          </div>

          {{!-- Ventajas y desventajas --}}
          <div class="tq-section-box" style="margin-bottom:0;">
            <div class="tq-section-header">
              <span>Ventajas y Desventajas</span>
              <a class="item-create" data-tipo="ventaja"><i class="fas fa-plus"></i></a>
            </div>
            <ul class="ventajas-list">
              {{#each items.ventajas as |vent|}}
              <li data-item-id="{{vent.id}}" class="ventaja-item tipo-{{vent.system.tipo}}">
                <strong>{{vent.name}}</strong>
                {{#if vent.system.coste}}
                  <span class="coste">({{vent.system.coste}} PP)</span>
                {{/if}}
                <span class="efecto">{{vent.system.efecto}}</span>
                <span class="item-controls">
                  <a class="item-edit" data-item-id="{{vent.id}}"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" data-item-id="{{vent.id}}"><i class="fas fa-trash"></i></a>
                </span>
              </li>
              {{/each}}
            </ul>
          </div>

          {{!-- Rasgos sobrenaturales y sociales --}}
          {{#if (or items.rasgos.length true)}}
          <div class="tq-section-box" style="margin-bottom:0;margin-top:4px;">
            <div class="tq-section-header">
              <span>Rasgos</span>
              <a class="item-create" data-tipo="rasgo"><i class="fas fa-plus"></i></a>
            </div>
            <ul class="ventajas-list">
              {{#each items.rasgos as |r|}}
              <li data-item-id="{{r.id}}" class="ventaja-item tipo-{{r.system.tipo}}">
                <strong>{{r.name}}</strong>
                {{#if r.system.coste}}
                  <span class="coste">({{r.system.coste}} PP)</span>
                {{/if}}
                <span class="efecto">{{r.system.efecto}}</span>
                <span class="item-controls">
                  <a class="item-edit" data-item-id="{{r.id}}"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" data-item-id="{{r.id}}"><i class="fas fa-trash"></i></a>
                </span>
              </li>
              {{/each}}
            </ul>
          </div>
          {{/if}}

          {{!-- Rasgos de personalidad --}}
          <div class="tq-section-box" style="margin-bottom:0;margin-top:4px;">
            <div class="tq-section-header">Rasgos de Personalidad</div>
            <div class="tq-section-content">
              <div class="rasgos-grid">
                <div class="rasgos-col">
                  <div class="rasgos-col-title rasgo-pos-title">Positivos</div>
                  <input type="text" name="system.rasgoPos1" value="{{system.rasgoPos1}}" placeholder="Rasgo positivo 1" class="rasgo-input rasgo-pos" />
                  <input type="text" name="system.rasgoPos2" value="{{system.rasgoPos2}}" placeholder="Rasgo positivo 2" class="rasgo-input rasgo-pos" />
                  <input type="text" name="system.rasgoPos3" value="{{system.rasgoPos3}}" placeholder="Rasgo positivo 3" class="rasgo-input rasgo-pos rasgo-extra" />
                </div>
                <div class="rasgos-col">
                  <div class="rasgos-col-title rasgo-neg-title">Negativos</div>
                  <input type="text" name="system.rasgoNeg1" value="{{system.rasgoNeg1}}" placeholder="Rasgo negativo 1" class="rasgo-input rasgo-neg" />
                  <input type="text" name="system.rasgoNeg2" value="{{system.rasgoNeg2}}" placeholder="Rasgo negativo 2" class="rasgo-input rasgo-neg" />
                  <input type="text" name="system.rasgoNeg3" value="{{system.rasgoNeg3}}" placeholder="Rasgo negativo 3" class="rasgo-input rasgo-neg rasgo-extra" />
                </div>
              </div>
            </div>
          </div>

        </div>{{!-- /col der --}}

      </div>{{!-- /fila principal --}}

      {{!-- FILA INFERIOR: ancho completo --}}
      <div style="display:flex;flex-direction:column;gap:4px;">

        {{!-- Guías Interpretativas --}}
        <div class="tq-section-box" style="margin-bottom:0;">
          <div class="tq-section-header">Guías Interpretativas</div>
          <div class="tq-section-content">
            <div class="guias-grid">
              <div class="guia-field full">
                <label>{{localize "TQ.Creacion.motivacion"}}</label>
                <input type="text" name="system.motivacion" value="{{system.motivacion}}" />
              </div>
              <div class="guia-field full">
                <label>{{localize "TQ.Creacion.tuMentira"}}</label>
                <input type="text" name="system.tuMentira" value="{{system.tuMentira}}" />
              </div>
              <div class="guia-field">
                <label>{{localize "TQ.Creacion.pasionAmor"}}</label>
                <input type="text" name="system.pasionAmor" value="{{system.pasionAmor}}" />
              </div>
              <div class="guia-field">
                <label>{{localize "TQ.Creacion.pasionOdio"}}</label>
                <input type="text" name="system.pasionOdio" value="{{system.pasionOdio}}" />
              </div>
            </div>
          </div>
        </div>

        {{!-- Notas --}}
        <div class="tq-section-box" style="margin-bottom:0;">
          <div class="tq-section-header">Notas</div>
          <div class="tq-section-content">
            <textarea class="notas-textarea" name="system.descripcion" rows="4">{{system.descripcion}}</textarea>
          </div>
        </div>

      </div>{{!-- /fila inferior --}}

      {{!-- Espaciador inferior --}}
      <div style="height:40px;background:var(--tq-parchment);border:none;"></div>

    </div>{{!-- /tab hoja2 --}}

  </section>{{!-- /sheet-body --}}

</div>
