<section class="{{cssClass}} flexcol" style="height:100%;width:100%;">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields pnj-header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Nombre" />
      </h1>
    </div>
  </header>

  <nav class="sheet-tabs">
    <a class="item active" data-tab="stats">Estadísticas</a>
    <a class="item" data-tab="combate">Combate y Magia</a>
    <a class="item" data-tab="notas">Notas</a>
  </nav>

  <section class="sheet-body">
    <div class="tab active" data-tab="stats">
      <div class="caract-grid">
        {{#each system.caracteristicas as |caract clave|}}
        <div class="caract-item">
          <span class="caract-etiqueta tirar-caracteristica" data-caracteristica="{{clave}}">
            {{localize (concat "TQ.Caracteristicas." clave)}}
          </span>
          <div class="caract-circulo">
            <input type="number" name="system.caracteristicas.{{clave}}.valor"
                   value="{{caract.valor}}" min="-5" max="20" />
          </div>
        </div>
        {{/each}}
      </div>

      <div class="derivadas-row">
        <div class="derivada-item">
          <span class="derivada-label tirar-caracteristica" data-caracteristica="fuerza" title="Tirar Fuerza" style="cursor:pointer;">Fuerza</span>
          <div class="caract-sec-circle">
            <span class="derivada-value">{{system.derivadas.fuerza.valor}}</span>
          </div>
        </div>
        <div class="derivada-item">
          <span class="derivada-label">MD 1M</span>
          <div class="caract-sec-circle">
            <span class="derivada-value">{{system.derivadas.mDano1m.valor}}</span>
          </div>
        </div>
        <div class="derivada-item">
          <span class="derivada-label">MD 2M</span>
          <div class="caract-sec-circle">
            <span class="derivada-value">{{system.derivadas.mDano2m.valor}}</span>
          </div>
        </div>
      </div>

      <div class="pnj-salud-centrada">
        <label class="pnj-salud-label">PV</label>
        <div class="pnj-salud-fila">
          <input type="number" name="system.salud.pvActual.valor" value="{{system.salud.pvActual.valor}}" class="pnj-pv-input" />
          <span class="pnj-salud-sep">/</span>
          <span class="pnj-pv-max">{{system.salud.pvMax.valor}}</span>
        </div>
      </div>

      <div class="section-header">
        <span>Habilidades</span>
        <a class="anadir-habilidad" title="Añadir habilidad"><i class="fas fa-plus"></i></a>
      </div>
      <div class="pnj-habilidades">
        {{#each system.habilidades as |valor nombre|}}
        <div class="pnj-hab" data-nombre="{{nombre}}">
          <span class="hab-nombre tirar-habilidad" data-nombre="{{nombre}}" data-valor="{{valor}}" title="Tirar {{nombre}}">{{nombre}}</span>
          <input type="number" name="system.habilidades.{{nombre}}"
                 value="{{valor}}" min="0" style="width:48px" />
          <a class="eliminar-habilidad" data-nombre="{{nombre}}" title="Eliminar">
            <i class="fas fa-trash"></i>
          </a>
        </div>
        {{/each}}
      </div>
    </div>

    <div class="tab" data-tab="combate">

      <div class="section-header">
        <span>Armas</span>
        <a class="anadir-arma" title="Añadir arma"><i class="fas fa-plus"></i></a>
      </div>
      {{#if armas}}
      <div class="pnj-items-lista">
        {{#each armas as |a|}}
        <div class="pnj-item-fila">
          <a class="pnj-item-nombre" data-id="{{a.id}}">{{a.name}}</a>
          <span class="pnj-item-detalle">{{a.dano}}</span>
          <a class="pnj-tirar-arma" data-id="{{a.id}}" title="Tirar"><i class="fas fa-dice-d10"></i></a>
          <a class="pnj-item-borrar" data-id="{{a.id}}" title="Eliminar"><i class="fas fa-trash"></i></a>
        </div>
        {{/each}}
      </div>
      {{/if}}

      <div class="section-header">
        <span>Protecciones</span>
        <a class="anadir-armadura" title="Añadir protección"><i class="fas fa-plus"></i></a>
      </div>
      {{#if armaduras}}
      <div class="pnj-items-lista">
        {{#each armaduras as |a|}}
        <div class="pnj-item-fila">
          <a class="pnj-item-nombre" data-id="{{a.id}}">{{a.name}}</a>
          <span class="pnj-item-detalle">PR {{a.proteccion}}</span>
          <a class="pnj-item-borrar" data-id="{{a.id}}" title="Eliminar"><i class="fas fa-trash"></i></a>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if rasgos}}
      <div class="section-header"><span>Rasgos</span></div>
      <div class="pnj-items-lista">
        {{#each rasgos as |r|}}
        <div class="pnj-item-fila">
          <a class="pnj-item-nombre" data-id="{{r.id}}">{{r.name}}</a>
          <a class="pnj-item-borrar" data-id="{{r.id}}" title="Eliminar"><i class="fas fa-trash"></i></a>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if ventajas}}
      <div class="section-header"><span>Ventajas / Desventajas</span></div>
      <div class="pnj-items-lista">
        {{#each ventajas as |v|}}
        <div class="pnj-item-fila">
          <a class="pnj-item-nombre" data-id="{{v.id}}">{{v.name}}</a>
          <a class="pnj-item-borrar" data-id="{{v.id}}" title="Eliminar"><i class="fas fa-trash"></i></a>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if objetos}}
      <div class="section-header"><span>Equipo</span></div>
      <div class="pnj-items-lista">
        {{#each objetos as |o|}}
        <div class="pnj-item-fila">
          <a class="pnj-item-nombre" data-id="{{o.id}}">{{o.name}}</a>
          {{#if o.categoria}}<span class="pnj-item-detalle">{{o.categoria}}</span>{{/if}}
          <a class="pnj-item-borrar" data-id="{{o.id}}" title="Eliminar"><i class="fas fa-trash"></i></a>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if consumibles}}
      <div class="section-header"><span>Consumibles</span></div>
      <div class="pnj-items-lista">
        {{#each consumibles as |c|}}
        <div class="pnj-item-fila">
          <a class="pnj-item-nombre" data-id="{{c.id}}">{{c.name}}</a>
          <span class="pnj-item-detalle">×{{c.dosis}}{{#if c.efecto}} · {{c.efecto}}{{/if}}</span>
          <a class="pnj-item-borrar" data-id="{{c.id}}" title="Eliminar"><i class="fas fa-trash"></i></a>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if system.pm}}
      <div class="section-header"><span>Magia</span></div>
      <div class="pnj-salud-centrada">
        <label class="pnj-salud-label">PM</label>
        <div class="pnj-salud-fila">
          <input type="number" name="system.pm" value="{{system.pm}}" class="pnj-pv-input" min="0" />
        </div>
      </div>
      {{/if}}

      {{#if hechizos}}
      <div class="section-header"><span>Hechizos</span></div>
      <ul class="hechizos-list">
        {{#each hechizos as |hech|}}
        <li class="hechizo-item" data-item-id="{{hech.id}}">
          <div class="hechizo-main">
            <span class="hechizo-nombre">{{hech.name}}</span>
            <span class="item-controls">
              <a class="pnj-tirar-hechizo" data-id="{{hech.id}}">Lanzar</a>
              <a class="item-edit" data-item-id="{{hech.id}}"><i class="fas fa-edit"></i></a>
              <a class="pnj-item-borrar" data-id="{{hech.id}}"><i class="fas fa-trash"></i></a>
            </span>
          </div>
          <div class="hechizo-meta">
            {{#if hech.system.verbo}}<span>{{hech.system.verbo}}{{#if hech.system.esfera}} {{hech.system.esfera}}{{/if}}</span><span class="hechizo-sep">|</span>{{/if}}
            <span>DIF. {{hech.system.dificultad}}</span>
            <span class="hechizo-sep">|</span>
            <span>PM {{hech.system.pmCoste}}{{#if (tq-gt hech.system.pmMax hech.system.pmCoste)}}-{{hech.system.pmMax}}{{/if}}</span>
            {{#if (tq-eq hech.system.duracion "instantaneo")}}<span class="hechizo-sep">|</span><span class="hechizo-badge">Inmediato</span>{{/if}}
            {{#if hech.system.requiereTiradaEspiritu}}<span class="hechizo-sep">|</span><span class="hechizo-espiritu" title="Requiere tirada enfrentada de Espíritu">⚔</span>{{/if}}
          </div>
        </li>
        {{/each}}
      </ul>
      {{/if}}

      {{#unless armas}}{{#unless armaduras}}{{#unless hechizos}}
      <p style="color:var(--tq-text-dim);font-size:13px;padding:8px;">Sin items de combate. Arrastra armas, armaduras o hechizos aquí.</p>
      {{/unless}}{{/unless}}{{/unless}}

    </div>

    <div class="tab" data-tab="notas">
      <textarea name="system.notas" rows="15" class="notas-textarea">{{system.notas}}</textarea>
    </div>
  </section>
</section>
