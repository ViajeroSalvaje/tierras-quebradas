<div class="cc-section">
  <h3 class="cc-section-title">Nombre del personaje</h3>
  <input type="text" id="cc-nombre" class="cc-nombre-input"
         value="{{data.nombre}}" placeholder="Nombre del personaje" autofocus />
</div>

<div class="cc-section">
  <h3 class="cc-section-title">Categoría de edad</h3>
  <div class="edad-grid">
    {{#each edades as |e|}}
    <div class="edad-card {{#if e.selected}}selected{{/if}}" data-edad="{{e.key}}">
      <div class="edad-card-header">
        <span class="edad-nombre">{{e.label}}</span>
        <span class="edad-rango">{{e.rango}}</span>
        <span class="edad-pp-badge">{{e.ppStr}}</span>
      </div>
      <div class="edad-card-body">
        <div class="edad-stat"><span class="edad-stat-label">Hab. libres</span><span class="edad-stat-val">{{e.puntosHab}}</span></div>
        <div class="edad-stat"><span class="edad-stat-label">Pts. caract.</span><span class="edad-stat-val">{{e.puntosCaract}}</span></div>
        <div class="edad-stat"><span class="edad-stat-label">Máx. Cuerpo</span><span class="edad-stat-val">{{e.maxCuerpo}}</span></div>
        {{#if e.maxTamanyo}}<div class="edad-stat"><span class="edad-stat-label">Máx. Tamaño</span><span class="edad-stat-val">+{{e.maxTamanyo}}</span></div>{{/if}}
      </div>
    </div>
    {{/each}}
  </div>
  <div class="cc-edad-num-fila">
    <label>Edad exacta</label>
    <input type="number" id="cc-edad-num" value="{{data.edadNumero}}" min="1" max="200" />
    <span class="cc-hint">({{edad.rango}})</span>
  </div>
</div>

{{#if reduccionesAleatorias}}
<div class="cc-aleatorio-reduccion-panel">
  <div class="cc-aleatorio-red-titulo">Ajuste automático por edad (método aleatorio)</div>
  {{#each reduccionesAleatorias as |r|}}
  <div class="cc-aleatorio-red-fila">
    <span class="cc-aleatorio-red-label">{{r.label}}</span>
    <span class="cc-aleatorio-red-base">{{r.base}}</span>
    <span class="cc-aleatorio-red-mod">{{r.mod}}</span>
    <span class="cc-aleatorio-red-arrow">→</span>
    <span class="cc-aleatorio-red-final">{{r.final}}</span>
  </div>
  {{/each}}
</div>
{{/if}}

{{#if hayConflicto}}
<div class="cc-conflicto-panel">
  <div class="cc-conflicto-titulo">⚠ Ajuste de características necesario</div>
  {{#if (tq-gt ptsExceso 0)}}
  <p>La categoría <strong>{{edad.label}}</strong> permite {{edad.puntosCaract}} puntos (tienes {{sumCaract}}). Debes retirar <strong>{{ptsExceso}} punto(s)</strong>.</p>
  {{/if}}
  {{#if conflictoCuerpo}}
  <p>Cuerpo no puede superar <strong>{{edad.maxCuerpo}}</strong> con esta edad (actualmente {{data.cuerpo}}).</p>
  {{/if}}
  <div class="cc-caract-grid" style="margin-top:8px;">
    {{#each caractLista as |c|}}
    <div class="cc-caract-fila">
      <span class="cc-caract-etiqueta">{{c.label}}</span>
      <button type="button" class="cc-caract-btn" data-caract="{{c.key}}" data-delta="-1">−</button>
      <span class="cc-caract-val">{{c.valor}}</span>
      <button type="button" class="cc-caract-btn" data-caract="{{c.key}}" data-delta="1">+</button>
    </div>
    {{/each}}
  </div>
</div>
{{/if}}
