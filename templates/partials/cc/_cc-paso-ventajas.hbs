<div class="cc-section">
  <div class="cc-ventajas-info">
    {{localize "TQ.CC.Seleccionadas"}} <strong>{{ventajasConteo}}/4</strong>
    <span class="cc-hint">{{localize "TQ.CC.NoObligatorio"}}</span>
  </div>

  <h3 class="cc-section-title">{{localize "TQ.CC.Ventajas"}}</h3>
  {{#if ventajasLista}}
  <div class="ventaja-grid">
    {{#each ventajasLista as |v|}}
    <div class="ventaja-card {{#if v.selected}}selected{{/if}} {{#if v.deshabilitada}}disabled{{/if}}"
         data-ventaja-id="{{v.id}}">
      <div class="ventaja-card-header">
        <span class="ventaja-nombre">{{v.name}}</span>
        <span class="ventaja-pp coste">{{v.costeBadge}}</span>
      </div>
      <p class="ventaja-efecto">{{v.efecto}}</p>
    </div>
    {{/each}}
  </div>
  {{else}}
  <p style="color:var(--tq-text-dim);font-size:13px;">{{localize "TQ.CC.RecargaVentajas"}}</p>
  {{/if}}

  <h3 class="cc-section-title cc-desventajas-title">{{localize "TQ.CC.Desventajas"}}</h3>
  {{#if desventajasLista}}
  <div class="ventaja-grid">
    {{#each desventajasLista as |v|}}
    <div class="ventaja-card desventaja {{#if v.selected}}selected{{/if}} {{#if v.deshabilitada}}disabled{{/if}}"
         data-ventaja-id="{{v.id}}">
      <div class="ventaja-card-header">
        <span class="ventaja-nombre">{{v.name}}</span>
        <span class="ventaja-pp bonus">{{v.costeBadge}}</span>
      </div>
      <p class="ventaja-efecto">{{v.efecto}}</p>
    </div>
    {{/each}}
  </div>
  {{/if}}
</div>
