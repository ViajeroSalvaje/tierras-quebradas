{{#if rasgosItemsData}}

{{#if rasgosItemsData.sobrenaturales.length}}
<div class="cc-section">
  <h3 class="cc-section-title">{{localize "TQ.CC.RasgosSobrenaturales"}}</h3>
  <div class="ventaja-grid">
    {{#each rasgosItemsData.sobrenaturales as |r|}}
    <div class="ventaja-card rasgo-card {{#if r.selected}}selected{{/if}} {{#if r.deshabilitada}}disabled{{/if}}"
         data-rasgo-id="{{r.id}}">
      <div class="ventaja-card-header">
        <span class="ventaja-nombre">{{r.name}}</span>
        <span class="ventaja-pp {{#if (tq-gt 0 r.coste)}}coste{{else}}bonus{{/if}}">{{r.costeBadge}}</span>
        {{#if r.esHechizos}}{{#if r.selected}}<span class="rasgo-cantidad">×{{r.cantidad}}</span><button class="rasgo-menos" type="button">−</button>{{/if}}{{/if}}
      </div>
      <p class="ventaja-efecto">{{r.efecto}}</p>
    </div>
    {{/each}}
  </div>
</div>
{{/if}}

{{#if rasgosItemsData.sociales.length}}
<div class="cc-section">
  <h3 class="cc-section-title">{{localize "TQ.CC.RasgosSociales"}}</h3>
  <div class="ventaja-grid">
    {{#each rasgosItemsData.sociales as |r|}}
    <div class="ventaja-card rasgo-card {{#if r.selected}}selected{{/if}} {{#if r.deshabilitada}}disabled{{/if}}"
         data-rasgo-id="{{r.id}}">
      <div class="ventaja-card-header">
        <span class="ventaja-nombre">{{r.name}}</span>
        <span class="ventaja-pp {{#if (tq-gt 0 r.coste)}}coste{{else}}bonus{{/if}}">{{r.costeBadge}}</span>
        {{#if r.esHechizos}}{{#if r.selected}}<span class="rasgo-cantidad">×{{r.cantidad}}</span><button class="rasgo-menos" type="button">−</button>{{/if}}{{/if}}
      </div>
      <p class="ventaja-efecto">{{r.efecto}}</p>
    </div>
    {{/each}}
  </div>
</div>
{{/if}}

{{else}}
<p class="cc-hint">{{localize "TQ.CC.RecargaRasgos"}}</p>
{{/if}}

{{#if rasgosData}}
<div class="cc-section">
  <h3 class="cc-section-title" style="margin-top:8px;">{{localize "TQ.Secciones.RasgosPersonalidad"}}
    <span class="cc-hint" style="font-weight:normal;">{{localize "TQ.CC.Opcional"}}</span>
  </h3>
  <div class="cc-rasgos-grid" style="margin-bottom:12px;">
    {{#each rasgosData.positivos as |r|}}
    <div class="cc-rasgo-fila">
      <label class="cc-rasgo-label">{{r.label}}</label>
      <input type="text" class="cc-rasgo-input" data-tipo="pos" data-idx="{{r.idx}}"
             value="{{r.valor}}" placeholder="{{localize "TQ.CC.RasgoPosPlaceholder"}}" />
    </div>
    {{/each}}
  </div>
  <div class="cc-rasgos-grid">
    {{#each rasgosData.negativos as |r|}}
    <div class="cc-rasgo-fila">
      <label class="cc-rasgo-label">{{r.label}}</label>
      <input type="text" class="cc-rasgo-input" data-tipo="neg" data-idx="{{r.idx}}"
             value="{{r.valor}}" placeholder="{{localize "TQ.CC.RasgoNegPlaceholder"}}" />
    </div>
    {{/each}}
  </div>
</div>
{{/if}}
