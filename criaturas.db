{"_id": "TQcr001", "name": "Dragón", "type": "criatura", "img": "icons/svg/mystery-man.svg", "system": {"caracteristicas": {"cuerpo": {"valor": 24}, "mente": {"valor": 3}, "espiritu": {"valor": 10}, "atractivo": {"valor": 0}, "tamano": {"valor": 20}}, "derivadas": {"fuerza": {"valor": 44}, "mDano1m": {"valor": 17}, "mDano2m": {"valor": 20}}, "bases": {"agilidad": {"valor": 0}, "comunicacion": {"valor": 0}, "cultura": {"valor": 0}, "hechiceria": {"valor": 0}, "percepcion": {"valor": 0}, "tecnica": {"valor": 0}, "vigor": {"valor": 0}}, "salud": {"pvMax": {"valor": 54}, "pvActual": {"valor": 54}, "pvRagunos": {"valor": 0}, "pvLeve": {"valor": 27}, "pvGrave": {"valor": 18}, "debilitado": false, "incapacitado": false, "muerto": false, "sanando": false}, "estorbo": {"valor": 0}, "carga": {"valor": 0}, "descripcion": "La criatura más poderosa de las Tierras Quebradas. Aliado de los merendrak. Duerme la mayor parte del tiempo (por cada día despierto, duerme un año).", "habilidades": {"atletismo": 8, "esquivar": 11, "percatarse": 14, "pelea": 30, "volar": 12, "escupirVeneno": 20}, "poderes": "Veneno ardiente: rociada sobre 400m² inflige 2d6 daño/turno a todos los presentes (tantas rociadas/día como CUE/2). Coletazo puede impactar a hasta 5 oponentes juntos (arma arrojadiza).", "debilidades": "", "tipo": "ANOMALÍA", "proteccion": {"valor": 10, "tipo": "dura"}, "alImpacto": 4, "movimiento": "Correr rápido. Volar rápido.", "pm": 0, "notas": ""}, "items": [], "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {}}
