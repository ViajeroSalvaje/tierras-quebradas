{"_id":"TQdm001","name":"Avispa naranja","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":9},"mente":{"valor":4},"espiritu":{"valor":5},"atractivo":{"valor":-4},"tamano":{"valor":2}},"derivadas":{"fuerza":{"valor":11},"mDano1m":{"valor":4},"mDano2m":{"valor":5}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":21},"pvActual":{"valor":21},"pvRagunos":{"valor":0},"pvLeve":{"valor":10},"pvGrave":{"valor":5},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio insectoide del tamaño de un humano, color naranja brillante con rayas negras. Vive en sociedad compleja gobernada por una reina, en una ciudad colmena en las junglas del Sur. Pueden generar bolas de luz anaranjada como espías.","habilidades":{"esquivar":13,"pelea":13,"percatarse":11,"perspicacia":9,"sigilo":10,"volar":15},"poderes":"Ayudantes: puede generar bolas de luz exploradoras. Veneno paralizante POT 9 en el aguijón.","debilidades":"","tipo":"DEMONIO","proteccion":{"valor":6,"tipo":"dura"},"alImpacto":0,"movimiento":"Trepar medio. Volar rápido.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Aguijón (Hab 13, Daño 2+4, Veneno paralizante POT 9). Presa (Hab 13, especial). Mandíbulas (Hab 13, Daño 2+4, Presa)."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm002","name":"Comadreja arco-iris","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":8},"mente":{"valor":12},"espiritu":{"valor":8},"atractivo":{"valor":-3},"tamano":{"valor":3}},"derivadas":{"fuerza":{"valor":11},"mDano1m":{"valor":4},"mDano2m":{"valor":5}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":21},"pvActual":{"valor":21},"pvRagunos":{"valor":0},"pvLeve":{"valor":10},"pvGrave":{"valor":5},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio de apariencia fantasmal y brillos cambiantes. Del tamaño de un hombre, con cabeza felina. Vanidoso e inteligente. Experto en magia y Multiverso; puede responder casi cualquier pregunta sobre estos temas. Desafía con acertijos a cambio de servicios.","habilidades":{"atletismo":11,"conocimientoMagico":19,"esquivar":13,"manipulacion":10,"multiverso":22,"pelea":11,"percatarse":18,"sigilo":10,"sueños":17},"poderes":"Presencia desconcertante: la primera vez que se presencia a una comadreja arco-iris se sufre un modificador de -2 a todas las acciones contra ella durante el primer minuto.","debilidades":"","tipo":"DEMONIO","proteccion":{"valor":1,"tipo":"blanda"},"alImpacto":0,"movimiento":"Correr rápido.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Mordisco (Hab 11, Daño 2+4, Presa)."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm003","name":"El Kulún","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":50},"mente":{"valor":1},"espiritu":{"valor":20},"atractivo":{"valor":0},"tamano":{"valor":40}},"derivadas":{"fuerza":{"valor":90},"mDano1m":{"valor":30},"mDano2m":{"valor":37}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":100},"pvActual":{"valor":100},"pvRagunos":{"valor":0},"pvLeve":{"valor":50},"pvGrave":{"valor":25},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio único de esencia venenosa. Cuerpo nebuloso negro del que surgen decenas de zarcillos. El lugar donde fue convocado durante la Gran Guerra es ahora una zona baldía. Invocación dif 25.","habilidades":{},"poderes":"Invulnerable a armas físicas (solo dañable por hechicería y fuego). Veneno de contacto: 3d6 PV de intoxicación a ritmo de 1 PV/turno. Generar zarcillo (3 PM cada uno): los zarcillos actúan como criaturas independientes (ver Zarcillo del Kulún). Tantos zarcillos/día como CUE/2.","debilidades":"Vulnerable a la hechicería y al fuego.","tipo":"DEMONIO ÚNICO","proteccion":{"valor":0,"tipo":"blanda"},"alImpacto":8,"movimiento":"Volar lento.","pm":0,"valorMagico":0,"vinculo":"","notas":"Sin armas directas; combate mediante zarcillos."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm004","name":"Gato de hielo","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":14},"mente":{"valor":3},"espiritu":{"valor":8},"atractivo":{"valor":0},"tamano":{"valor":6}},"derivadas":{"fuerza":{"valor":20},"mDano1m":{"valor":7},"mDano2m":{"valor":9}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":30},"pvActual":{"valor":30},"pvRagunos":{"valor":0},"pvLeve":{"valor":15},"pvGrave":{"valor":7},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio del Averno Gélido del tamaño de un caballo, hecho de un líquido congelado. Cuerpo de cualquier color, carece de pelaje. Ojos rojos brillantes. No habla. Solo ataca a mujeres en defensa propia o por atadura.","habilidades":{"ataqueDerociada":15,"atletismo":12,"esquivar":13,"pelea":18,"percatarse":9,"sigilo":13},"poderes":"Ataque de rociada: Escarcha (chorro frío). Consistencia pétrea: resistencia aumentada. Al morir sus cuerpos son macizos y sin órganos internos.","debilidades":"Vulnerable al fuego. Exclusión de presa: no ataca a mujeres salvo en defensa propia o por atadura.","tipo":"DEMONIO","proteccion":{"valor":3,"tipo":"dura"},"alImpacto":1,"movimiento":"Correr rápido.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Mordisco (Hab 18, Daño 3+7, Presa). Chorro de escarcha (Hab 15, Daño 3)."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm005","name":"Hombre basilisco","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":10},"mente":{"valor":6},"espiritu":{"valor":6},"atractivo":{"valor":-4},"tamano":{"valor":4}},"derivadas":{"fuerza":{"valor":14},"mDano1m":{"valor":5},"mDano2m":{"valor":7}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":24},"pvActual":{"valor":24},"pvRagunos":{"valor":0},"pvLeve":{"valor":12},"pvGrave":{"valor":6},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio en parte ave, lagarto y humano. Se comunican con siseos. Su carne y fluidos son altamente venenosos; donde pisan la hierba no vuelve a crecer. Las hembras dejan huevos que eclosionan al día siguiente.","habilidades":{"armasAsta":17,"atletismo":13,"escupitajo":12,"esquivar":14,"lanzar":15,"pelea":14,"percatarse":12,"perspicacia":10,"sigilo":10},"poderes":"Inmunidad al veneno. Veneno (POT 10, -1 PV/turno) en todas sus armas. Vitalidad extraordinaria: no sufren el estado Debilitado. Escupitajo (con 5 puntos de éxito): el líquido cae en ojos o labios, intoxicando a la víctima.","debilidades":"","tipo":"DEMONIO","proteccion":{"valor":0,"tipo":"blanda"},"alImpacto":0,"movimiento":"Correr medio.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Jabalina 2M (Hab 17, Daño 2+7). Jabalina arrojadiza (Hab 15, Daño 4+5, alcance medio). Escupitajo (Hab 12, envenena, alcance corto). Armas envenenadas POT 10."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm006","name":"Hombre jabalí","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":8},"mente":{"valor":3},"espiritu":{"valor":4},"atractivo":{"valor":-3},"tamano":{"valor":2}},"derivadas":{"fuerza":{"valor":10},"mDano1m":{"valor":3},"mDano2m":{"valor":4}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":20},"pvActual":{"valor":20},"pvRagunos":{"valor":0},"pvLeve":{"valor":10},"pvGrave":{"valor":5},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio originalmente al servicio de Shonbark. Aspecto de jabalí bípedo. Bestiales y de costumbres sucias. Muchos llevan siglos viviendo en los bosques profundos de Frondas. Van acompañados de una singular pestilencia.","habilidades":{"atletismo":10,"armasMangos":12,"esquivar":11,"pelea":13,"percatarse":7,"perspicacia":7,"sigilo":9,"trepar":10},"poderes":"Regeneración: sus heridas se cierran rápidamente.","debilidades":"Presencia evidente.","tipo":"DEMONIO","proteccion":{"valor":0,"tipo":"blanda"},"alImpacto":0,"movimiento":"Correr medio.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Garrote 2M (Hab 12, Daño 3+4). Golpe corporal (Hab 13, Daño 0+3). Presa (Hab 11, especial)."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm007","name":"Libélula humanoide","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":15},"mente":{"valor":3},"espiritu":{"valor":5},"atractivo":{"valor":-4},"tamano":{"valor":9}},"derivadas":{"fuerza":{"valor":24},"mDano1m":{"valor":8},"mDano2m":{"valor":10}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":34},"pvActual":{"valor":34},"pvRagunos":{"valor":0},"pvLeve":{"valor":17},"pvGrave":{"valor":8},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio con torso humano grande, cuatro brazos con garras y cuatro alas de libélula de 15m de envergadura. Burdos y estúpidos pero letales. Invocados para encontrar y destruir enemigos. Raramente viven más de 1 día tras ser invocados.","habilidades":{"esquivar":15,"pelea":19,"percatarse":8,"volar":12},"poderes":"Miembros suplementarios: cuatro brazos, puede atacar con dos pares. Infundir miedo (2 PM): enfrenta ESP vs ESP; si gana, la víctima solo puede defender, huir o esconderse tantos turnos como ESP de la libélula.","debilidades":"Vida efímera: rara vez viven más de 1 día tras ser invocadas.","tipo":"DEMONIO","proteccion":{"valor":2,"tipo":"dura"},"alImpacto":1,"movimiento":"Correr medio. Volar rápido.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Garra (Hab 19, Daño 2+8, Combo). Presa (Hab 17, especial). Piden huevo a cuidar a cambio de servicios; la larva se transforma en libélula humanoide en 3 meses."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm008","name":"Octocéfalo","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":12},"mente":{"valor":4},"espiritu":{"valor":8},"atractivo":{"valor":-4},"tamano":{"valor":6}},"derivadas":{"fuerza":{"valor":18},"mDano1m":{"valor":6},"mDano2m":{"valor":8}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":28},"pvActual":{"valor":28},"pvRagunos":{"valor":0},"pvLeve":{"valor":14},"pvGrave":{"valor":7},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio obeso sin cabeza propia. Puede colocarse cabezas humanas muertas (hasta 8), usando los recuerdos y habilidades de sus dueños originales. Cada cabeza suma +1 MEN. No puede ser atado. Estadísticas sin ninguna cabeza.","habilidades":{"atletismo":12,"esquivar":10,"manipulacion":7,"pelea":17,"perspicacia":12},"poderes":"Cabeza adicional (hasta 8): cada cabeza otorga habilidades del antiguo dueño y +1 MEN. Radar: percibe el entorno sin usar la vista. Las cabezas tienen CUE:7, MEN:6, ESP:8, ATR:0, FUE:2, TAM:-5, Prot:3 dura, Mandíbula 10 (0+1, Presa).","debilidades":"No puede ser atado.","tipo":"DEMONIO","proteccion":{"valor":1,"tipo":"blanda"},"alImpacto":1,"movimiento":"Correr lento.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Golpe corporal (Hab 17, Daño 0+6). Presa (Hab 15, especial). Varios de ellos pueden seguir en las Tierras Quebradas desde que fueron invocados."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm009","name":"Pulpo gigante","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":17},"mente":{"valor":3},"espiritu":{"valor":8},"atractivo":{"valor":0},"tamano":{"valor":12}},"derivadas":{"fuerza":{"valor":29},"mDano1m":{"valor":10},"mDano2m":{"valor":13}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":39},"pvActual":{"valor":39},"pvRagunos":{"valor":0},"pvLeve":{"valor":19},"pvGrave":{"valor":9},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"El kraken. Hijo de Yarói, venerado por sus seguidores. Inteligencia en el límite de lo racional. Recuerda a amigos y enemigos. Puede volcar embarcaciones pequeñas y enroscar su cuerpo en barcos mayores para partirlos.","habilidades":{"esquivar":9,"nadar":12,"pelea":21,"percatarse":8},"poderes":"Varios tentáculos: puede involucrarse en dos melés a la vez con sus tentáculos, funcionando como dos adversarios (incluyendo superioridad numérica). Presa fácil con los tentáculos. La fauces solo se usan en combate cerrado.","debilidades":"","tipo":"DEMONIO","proteccion":{"valor":3,"tipo":"blanda"},"alImpacto":2,"movimiento":"Nadar rápido.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Tentáculo (Hab 21, Daño 2+10, Presa fácil). Fauces (Hab 21, Daño 4+10, solo combate cerrado)."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm010","name":"Quelque","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":14},"mente":{"valor":3},"espiritu":{"valor":13},"atractivo":{"valor":-4},"tamano":{"valor":10}},"derivadas":{"fuerza":{"valor":24},"mDano1m":{"valor":8},"mDano2m":{"valor":10}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":34},"pvActual":{"valor":34},"pvRagunos":{"valor":0},"pvLeve":{"valor":17},"pvGrave":{"valor":8},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio único con forma de larva blanca de 4m. Ciego al mundo natural pero ve y rastrea almas. Se alimenta de espíritus. Brutal y estúpido. Puede contraer su cuerpo para saltar hasta 10m. A cambio de servicios pide almas frescas e inocentes.","habilidades":{"esquivar":9,"percatarse":10,"pelea":20},"poderes":"Radar. Rastrear almas. Saltar (hasta 10m). Devorar almas (3 PM): enfrenta ESP vs ESP, absorbe tantos PM como puntos de éxito; al agotar PM, daña directamente ESP. Puede repetir la tirada cada turno mientras gane.","debilidades":"Presencia evidente.","tipo":"DEMONIO ÚNICO","proteccion":{"valor":3,"tipo":"blanda"},"alImpacto":2,"movimiento":"Deslizarse lento.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Aplastar (Hab 20, Daño 2+10, aprovecha para devorar alma)."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm011","name":"Simio emplumado","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":10},"mente":{"valor":3},"espiritu":{"valor":6},"atractivo":{"valor":0},"tamano":{"valor":4}},"derivadas":{"fuerza":{"valor":14},"mDano1m":{"valor":5},"mDano2m":{"valor":7}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":24},"pvActual":{"valor":24},"pvRagunos":{"valor":0},"pvLeve":{"valor":12},"pvGrave":{"valor":6},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio del Caos con cabeza y torso de simio de piel negra y pelo verde, alas en lugar de brazos y patas de ave rapaz. Plumaje vistoso. Viven en manadas de ~12 en cuevas y ruinas del Continente Sur. Su presencia se delata por un intenso perfume dulzón.","habilidades":{"esquivar":10,"pelea":15,"percatarse":9,"rastrear":10,"sigilo":7,"trepar":13,"volar":12},"poderes":"Náusea insoportable (2 PM): segregación intensa de olor; -1 a acciones si está a <15m, -2 en combate cuerpo a cuerpo; dura tantos turnos como ESP. Puede atrapar a una persona entre dos, elevarla y dejarla caer.","debilidades":"Presencia evidente.","tipo":"DEMONIO","proteccion":{"valor":1,"tipo":"blanda"},"alImpacto":0,"movimiento":"Correr medio. Volar medio.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Garra (Hab 15, Daño 1+5, Combo). Mordisco (Hab 15, Daño 2+5, Presa)."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm012","name":"Solfirhuv","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":11},"mente":{"valor":5},"espiritu":{"valor":10},"atractivo":{"valor":-4},"tamano":{"valor":5}},"derivadas":{"fuerza":{"valor":16},"mDano1m":{"valor":5},"mDano2m":{"valor":7}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":26},"pvActual":{"valor":26},"pvRagunos":{"valor":0},"pvLeve":{"valor":13},"pvGrave":{"valor":6},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio del Plano Espejo. Humanoide simiesco de más de 2m, con dos rostros, dos tórax, cuatro brazos y cuatro piernas. Van armados con escudos, redes y cimitarras. Les apasiona luchar y acceden gustosos a combates.","habilidades":{"escudo":18,"armasEspada":18,"armasRed":16,"atletismo":12,"esquivar":17,"pelea":18,"trepar":18},"poderes":"Cabeza adicional: dos rostros. Miembros suplementarios: cuatro brazos. Sangre espesa: inmune a heridas de Desangre.","debilidades":"","tipo":"DEMONIO","proteccion":{"valor":6,"tipo":"dura"},"alImpacto":1,"movimiento":"Correr medio.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Red (Hab 16, atrapa). Cimitarra (Hab 18, Daño 4+5). Escudo (Hab 18, Daño 1+5). Protección de dos escudos grandes."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm013","name":"Súcubo púrpura","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":5},"mente":{"valor":9},"espiritu":{"valor":8},"atractivo":{"valor":4},"tamano":{"valor":-1}},"derivadas":{"fuerza":{"valor":4},"mDano1m":{"valor":1},"mDano2m":{"valor":2}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":14},"pvActual":{"valor":14},"pvRagunos":{"valor":0},"pvLeve":{"valor":7},"pvGrave":{"valor":3},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio del Caos con apariencia de mujer de belleza extraordinaria. Franjas púrpura en espalda y muslos, cola flexible. Invocada principalmente con fines recreativos. Quien yazca con ella experimenta días de vacío y amargura.","habilidades":{"encanto":20,"esquivar":10,"percatarse":12,"manipulacion":16,"pelea":8,"sigilo":13},"poderes":"Inducir emociones: Lujuria (3 PM): enfrenta ESP vs ESP; dura tantos minutos como ESP. Dormir (5 PM): enfrenta ESP vs ESP; víctima duerme tantas horas como ESP.","debilidades":"","tipo":"DEMONIO","proteccion":{"valor":0,"tipo":"blanda"},"alImpacto":0,"movimiento":"Correr medio.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Golpe corporal (Hab 8, Daño 0+1)."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm014","name":"Tortuga metalófaga","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":17},"mente":{"valor":3},"espiritu":{"valor":7},"atractivo":{"valor":0},"tamano":{"valor":14}},"derivadas":{"fuerza":{"valor":31},"mDano1m":{"valor":10},"mDano2m":{"valor":13}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":41},"pvActual":{"valor":41},"pvRagunos":{"valor":0},"pvLeve":{"valor":20},"pvGrave":{"valor":10},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio de 5m de altura, caparazón pétro-metálico, patas como pilares escamosas. Se alimenta de metales y especialmente de hombres con armadura. Pasa largos periodos durmiendo. Sus huevos parecen formaciones rocosas.","habilidades":{"esquivar":6,"pelea":21,"percatarse":11},"poderes":"Hacer estallar (3 PM): enfrenta ESP vs ESP, si gana inflige tantos PD como su ESP.","debilidades":"","tipo":"DEMONIO","proteccion":{"valor":12,"tipo":"dura"},"alImpacto":2,"movimiento":"Correr lento.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Mordisco (Hab 21, Daño 5+10, Presa). Pisoteo (Hab 21, Daño 5+13, contra enemigo en el suelo)."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm015","name":"Tragador","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":14},"mente":{"valor":8},"espiritu":{"valor":11},"atractivo":{"valor":-4},"tamano":{"valor":5}},"derivadas":{"fuerza":{"valor":19},"mDano1m":{"valor":4},"mDano2m":{"valor":5}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":29},"pvActual":{"valor":29},"pvRagunos":{"valor":0},"pvLeve":{"valor":14},"pvGrave":{"valor":7},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Demonio inteligente con cierto sentido del humor. Humanoide abotargado sin cabellos, seis brazos largos con venas de colores. Invocado para custodiar tesoros. Solo puede atacar a quien entre indebidamente en su territorio. No puede mentir.","habilidades":{"esquivar":15,"pelea":18,"percatarse":14,"perspicacia":15},"poderes":"Invulnerable a armas mundanas. Miembros suplementarios: seis brazos. Tragar (3 PM): como acción de presa, puede tragarse a un ser de TAM +3 o menor; los tragados pueden acabar en el Caos.","debilidades":"No puede mentir.","tipo":"DEMONIO","proteccion":{"valor":4,"tipo":"blanda"},"alImpacto":1,"movimiento":"Correr rápido.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Presa (Hab 16, Daño: Tragar)."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm016","name":"Tritón","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":9},"mente":{"valor":6},"espiritu":{"valor":6},"atractivo":{"valor":-4},"tamano":{"valor":3}},"derivadas":{"fuerza":{"valor":12},"mDano1m":{"valor":4},"mDano2m":{"valor":5}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":22},"pvActual":{"valor":22},"pvRagunos":{"valor":0},"pvLeve":{"valor":11},"pvGrave":{"valor":5},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Raza humanoide submarina vástagos de Yarói. Humanos de cintura arriba (sin vello, ojos grandes azules, cresta de espinas) y cola de tritón abajo. Habitan ciudades subterráneas. No envejecen. Si pierden un miembro, este crece como un nuevo tritón idéntico con sus recuerdos.","habilidades":{"armasAsta":13,"escudo":11,"armasEspada":12,"atletismo":10,"manipulacion":7,"lanzar":11,"nadar":13,"pelea":10,"percatarse":10,"perspicacia":9,"sigilo":9,"trepar":9},"poderes":"Regeneración: un miembro amputado crece formando un nuevo tritón idéntico con los recuerdos del original.","debilidades":"En tierra se mueven lento (máximo velocidad de persona andando).","tipo":"DEMONIO","proteccion":{"valor":3,"tipo":"blanda"},"alImpacto":0,"movimiento":"Correr lento. Nadar medio.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Tridente (Hab 13, Daño 3+5). Jabalina (Hab 13, Daño 3+4). Jabalina arrojadiza (Hab 11, Daño 4+4, alcance medio). Escudo medio (Hab 11, Daño 0+4). Espada corta (Hab 12, Daño 3+4). Nunca portan armadura. Hablan tilés y merení."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"TQdm017","name":"Zarcillo del Kulún","type":"demonio","img":"icons/svg/mystery-man.svg","system":{"caracteristicas":{"cuerpo":{"valor":8},"mente":{"valor":1},"espiritu":{"valor":20},"atractivo":{"valor":0},"tamano":{"valor":4}},"derivadas":{"fuerza":{"valor":12},"mDano1m":{"valor":4},"mDano2m":{"valor":5}},"bases":{"agilidad":{"valor":0},"comunicacion":{"valor":0},"cultura":{"valor":0},"hechiceria":{"valor":0},"percepcion":{"valor":0},"tecnica":{"valor":0},"vigor":{"valor":0}},"salud":{"pvMax":{"valor":22},"pvActual":{"valor":22},"pvRagunos":{"valor":0},"pvLeve":{"valor":11},"pvGrave":{"valor":5},"debilitado":false,"incapacitado":false,"muerto":false,"sanando":false},"estorbo":{"valor":0},"carga":{"valor":0},"descripcion":"Apéndice del Kulún. El Kulún puede generar nuevos zarcillos al coste de 3 PM cada uno. Actúan como criaturas independientes. La presa es convencional: primero atrapan, luego infligen daño cada turno. Su contacto es venenoso.","habilidades":{"esquivar":6,"pelea":11},"poderes":"Veneno de contacto del Kulún: 3d6 PV de intoxicación a ritmo de 1 PV/turno.","debilidades":"","tipo":"DEMONIO","proteccion":{"valor":0,"tipo":"blanda"},"alImpacto":0,"movimiento":"Volar medio.","pm":0,"valorMagico":0,"vinculo":"","notas":"Armas: Presa (Hab 11, especial + veneno). Extensión del Kulún — no se invoca de forma independiente."},"items":[],"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
